{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "module": "commonjs",
        "moduleResolution": "node",
        "outDir": "dist-server",
        "rootDir": ".",
        "noEmit": false,
        "isolatedModules": false,
        "paths": {
        "@/*": [
            "./*"
        ]
        }
    },
    "include": [
        "server/socket-server.ts",
        "server/shared/**/*.ts",
        "server/socket-server/**/*.ts",
        "server/rmhbox/**/*.ts",
        "server/rmhtube/**/*.ts",
        "server/discord-bot/**/*.ts",
        "server/discord-bot/**/*.tsx",
        "lib/rmhbox/**/*.ts",
        "lib/blackjack/logic.ts",
        "lib/lights-out/**/*.ts"
    ]
}