# ─── Dependencies & build artifacts ──────────────────────────────────
# `node_modules` only matches the context root; `**/node_modules` is needed to
# catch nested copies (e.g. a stray `.next/node_modules/@prisma/client-<hash>`,
# whose transient files otherwise race the COPY checksum and fail the build).
node_modules
**/node_modules
.next
.output
.vinxi
.tanstack
dist-server
.pnpm-store

# ─── Version control ────────────────────────────────────────────────
.git
.gitignore

# ─── Environment files (injected at runtime, not baked into image) ──
.env
.env.*
!.env.example

# ─── Security ───────────────────────────────────────────────────────
*.pem

# ─── Dev / editor files ─────────────────────────────────────────────
.DS_Store
.vscode
.claude
.venv
coverage
.rmhbot-worktrees

# ─── Docker files (no recursion) ────────────────────────────────────
Dockerfile
Dockerfile.*
docker-compose*.yml
.dockerignore

# ─── CLI sub-package ────────────────────────────────────────────────
cli/dist
cli/node_modules

# ─── DB artifacts ───────────────────────────────────────────────────
db/avatars
db/builds
db/music

# ─── Heavy static media served from Cloudflare R2 (not the image) ───────────
# /library, /music and /sprites are served from R2 behind cdn.rmhstudios.com
# (see lib/storage/asset.ts), not off disk and not from the Node image — the
# host checkout is only the sync source for scripts/sync-static-assets-to-r2.mjs.
# Keeping them out shrinks the build context, the COPY public layer, the build
# cache, AND the runtime image.
#   - music/sprites: excluded entirely.
#   - models: kept IN the image — it's small (~20 MB), nothing references it via
#     the CDN asset() helper, and the Dockerfile smoke-tests marlonjack.glb.
#   - library: only the heavy PDFs (~488 MB) are excluded; covers/ stays so the
#     metadata step can see them. data/library-metadata.json (committed) carries
#     the catalogue. Adding a NEW library PDF requires running
#     `pnpm run library:metadata` locally and committing its cover + the JSON.
public/music
public/sprites
public/library/*.pdf
public/**/*.psd
public/**/generate_sprites.py

# ─── Generated at build time (regenerated by build-vibe-packages) ───────────
# scripts/build-vibe-packages.ts rebuilds these during `vite build`, so shipping
# the host's generated copy in the context is pure waste (and risks staleness).
public/vibe-packages

# ─── Unused scripts ─────────────────────────────────────────────────
scripts/news-pipeline

# ─── Documentation ──────────────────────────────────────────────────
docs
*.md
!README.md

# ─── Go microservices fleet + new infra ──────────────────────────────
# go-services is included so the go-builder stage can compile supervisor,
# status, and bot-worker into /app/bin. Only deploy/ and .github/ are
# excluded from the context (they are never needed inside the image).
deploy
.github

# ─── Testing ────────────────────────────────────────────────────────
testing
specs
vitest.config.ts
