# ─── Dependencies & build artifacts ──────────────────────────────────
node_modules
.output
.vinxi
.tanstack
dist-server
.pnpm-store

# ─── Version control ────────────────────────────────────────────────
.git
.gitignore

# ─── Environment files (injected at runtime, not baked into image) ──
.env
.env.*
!.env.example

# ─── Security ───────────────────────────────────────────────────────
*.pem

# ─── Dev / editor files ─────────────────────────────────────────────
.DS_Store
.vscode
.claude
.venv
coverage
.rmhbot-worktrees

# ─── Docker files (no recursion) ────────────────────────────────────
Dockerfile
Dockerfile.*
docker-compose*.yml
.dockerignore

# ─── CLI sub-package ────────────────────────────────────────────────
cli/dist
cli/node_modules

# ─── DB artifacts ───────────────────────────────────────────────────
db/avatars
db/builds
db/music

# ─── Dormant public media during lockdown ──────────────────────────
# The live lockdown page only needs favicon.svg, public/models/, and bundled
# Vite assets. These large legacy game/audio assets can push small Docker hosts
# over their overlay storage limit during COPY public ./public/.
public/music
public/sprites
public/**/*.psd
public/**/generate_sprites.py

# ─── Unused scripts ─────────────────────────────────────────────────
scripts/news-pipeline

# ─── Documentation ──────────────────────────────────────────────────
docs
*.md
!README.md

# ─── Go microservices fleet + new infra (not part of the web image) ──
# Keeps these out of the `COPY . .` build context so adding them never
# busts the web image cache or triggers an unnecessary container recreate.
go-services
deploy
.github

# ─── Testing ────────────────────────────────────────────────────────
testing
specs
vitest.config.ts
