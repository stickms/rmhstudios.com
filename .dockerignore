cli/dist
cli/node_modules

# ─── DB artifacts ───────────────────────────────────────────────────
db/avatars
db/builds
db/music

# ─── Public media served by Apache off the host disk (not the image) ────────
# Apache serves /music and /sprites directly from the host's public/ checkout
# (see deploy/apache/rmhstudios.com.conf), so they don't belong in the build
# context or the image. Keeping them out shrinks the context, the COPY public
# layer, the build cache, AND the runtime image.
#   - music/sprites: excluded entirely.
#   - library: only the heavy PDFs (~488 MB) are excluded; covers/ stays so the
#     metadata step can see them. data/library-metadata.json (committed) carries
#     the catalogue. Adding a NEW library PDF requires running
#     `pnpm run library:metadata` locally and committing its cover + the JSON.
#   - models: still shipped in the build context (Dockerfile sanity-checks
#     public/models/marlonjack.glb). Exclusion deferred to Phase 4 — see block
#     below.
public/library/*.pdf
public/music
public/sprites

# ── Assets/CDN cutover — Phase 4 (see docs/runbooks/go-backend-and-bazel.md) ──
# Uncomment these ONLY after /library and /models are served from the bucket by
# the Go assets service. Activating them drops ~500 MB from the build context.
# When you uncomment public/models, you MUST also remove the
# `test -f .../public/models/marlonjack.glb` sanity check in the Node Dockerfile
# (the file will no longer be in the build context).
# public/library
# public/models
public/**/*.psd
public/**/generate_sprites.py

# ─── Generated at build time (regenerated by build-vibe-packages) ───────────
# scripts/build-vibe-packages.ts rebuilds these during `vite build`, so shipping
# the host's generated copy in the context is pure waste (and risks staleness).
public/vibe-packages

# ─── Unused scripts ─────────────────────────────────────────────────
scripts/news-pipeline

# ─── Documentation ──────────────────────────────────────────────────
docs
*.md
!README.md

# ─── Go microservices fleet + new infra (not part of the web image) ──
# Keeps these out of the `COPY . .` build context so adding them never
# busts the web image cache or triggers an unnecessary container recreate.
go-services
deploy
.github

# ─── Testing ────────────────────────────────────────────────────────
testing
specs
vitest.config.ts
