# ─── Dependencies & build artifacts ──────────────────────────────────
node_modules
.output
.vinxi
.tanstack
dist-server
.pnpm-store

# ─── Version control ────────────────────────────────────────────────
.git
.gitignore

# ─── Environment files (injected at runtime, not baked into image) ──
.env
.env.*
!.env.example

# ─── Security ───────────────────────────────────────────────────────
*.pem

# ─── Dev / editor files ─────────────────────────────────────────────
.DS_Store
.vscode
.claude
.venv
coverage
.rmhbot-worktrees

# ─── Docker files (no recursion) ────────────────────────────────────
Dockerfile
Dockerfile.*
docker-compose*.yml
.dockerignore

# ─── CLI sub-package ────────────────────────────────────────────────
cli/dist
cli/node_modules

# ─── DB artifacts ───────────────────────────────────────────────────
db/avatars
db/builds
db/music

# ─── Public media served by Apache off the host disk (not the image) ────────
# Apache serves /library, /music, /models and /sprites directly from the host's
# public/ checkout (see deploy/apache/rmhstudios.com.conf), so they don't belong
# in the build context or the image. Keeping them out shrinks the context, the
# COPY public layer, the build cache, AND the runtime image.
#   - music/sprites: excluded entirely.
#   - library: only the heavy PDFs (~488 MB) are excluded; covers/ stays so the
#     metadata step can see them. data/library-metadata.json (committed) carries
#     the catalogue. Adding a NEW library PDF requires running
#     `pnpm run library:metadata` locally and committing its cover + the JSON.
public/music
public/sprites
public/library/*.pdf
public/**/*.psd
public/**/generate_sprites.py

# ─── Generated at build time (regenerated by build-vibe-packages) ───────────
# scripts/build-vibe-packages.ts rebuilds these during `vite build`, so shipping
# the host's generated copy in the context is pure waste (and risks staleness).
public/vibe-packages

# ─── Unused scripts ─────────────────────────────────────────────────
scripts/news-pipeline

# ─── Documentation ──────────────────────────────────────────────────
docs
*.md
!README.md

# ─── Go microservices fleet + new infra ──────────────────────────────
# go-services is included so the go-builder stage can compile supervisor,
# status, and bot-worker into /app/bin. Only deploy/ and .github/ are
# excluded from the context (they are never needed inside the image).
deploy
.github

# ─── Testing ────────────────────────────────────────────────────────
testing
specs
vitest.config.ts
