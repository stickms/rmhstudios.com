// ─── RMHark (Feed) Models ─────────────────────────────────────────

model RMHark {
  id        String   @id @default(cuid())
  userId    String
  content   String   @db.Text
  gifUrl    String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes     RMHarkLike[]
  comments  RMHarkComment[]
  reposts   RMHarkRepost[]
  views     RMHarkView[]
  poll      RMHarkPoll?

  // Self-relation for reposts (quote-repost displays the original inline)
  originalId String?
  original   RMHark?  @relation("RMHarkReposts", fields: [originalId], references: [id], onDelete: SetNull)
  repostedBy RMHark[] @relation("RMHarkReposts")

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("rmheet")
}

model RMHarkLike {
  id        String   @id @default(cuid())
  rmheetId  String
  userId    String
  createdAt DateTime @default(now())

  rmhark    RMHark   @relation(fields: [rmheetId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([rmheetId, userId])
  @@map("rmheet_like")
}

model RMHarkComment {
  id        String   @id @default(cuid())
  rmheetId  String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rmhark    RMHark   @relation(fields: [rmheetId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Optional threaded replies
  parentId  String?
  parent    RMHarkComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies   RMHarkComment[] @relation("CommentReplies")

  // Engagement
  likes     RMHarkCommentLike[]
  reposts   RMHarkCommentRepost[]
  views     RMHarkCommentView[]

  @@index([rmheetId, createdAt(sort: Desc)])
  @@map("rmheet_comment")
}

model RMHarkCommentLike {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment   RMHarkComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@map("rmheet_comment_like")
}

model RMHarkCommentRepost {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment   RMHarkComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@map("rmheet_comment_repost")
}

model RMHarkCommentView {
  id        String   @id @default(cuid())
  commentId String
  userId    String?
  ipHash    String?
  createdAt DateTime @default(now())

  comment   RMHarkComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@unique([commentId, ipHash])
  @@index([commentId])
  @@map("rmheet_comment_view")
}

model RMHarkRepost {
  id        String   @id @default(cuid())
  rmheetId  String
  userId    String
  createdAt DateTime @default(now())

  rmhark    RMHark   @relation(fields: [rmheetId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([rmheetId, userId])
  @@map("rmheet_repost")
}

model RMHarkView {
  id        String   @id @default(cuid())
  rmheetId  String
  userId    String?
  ipHash    String?
  createdAt DateTime @default(now())

  rmhark    RMHark   @relation(fields: [rmheetId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([rmheetId, userId])
  @@unique([rmheetId, ipHash])
  @@index([rmheetId])
  @@map("rmheet_view")
}

model RMHarkPoll {
  id          String   @id @default(cuid())
  rmheetId    String   @unique
  question    String   @db.VarChar(200)
  multiSelect Boolean  @default(false)
  createdAt   DateTime @default(now())

  rmhark  RMHark             @relation(fields: [rmheetId], references: [id], onDelete: Cascade)
  options RMHarkPollOption[]

  @@map("rmheet_poll")
}

model RMHarkPollOption {
  id       String @id @default(cuid())
  pollId   String
  text     String @db.VarChar(80)
  position Int

  poll  RMHarkPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes RMHarkPollVote[]

  @@index([pollId])
  @@map("rmheet_poll_option")
}

model RMHarkPollVote {
  id        String   @id @default(cuid())
  optionId  String
  userId    String
  createdAt DateTime @default(now())

  option RMHarkPollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([optionId, userId])
  @@index([optionId])
  @@map("rmheet_poll_vote")
}

// ─── User Profile (Social) ──────────────────────────────────────

model UserProfile {
