generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User Model (Better Auth)
model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique // Added for username login
  email         String?   @unique
  emailVerified Boolean?
  password      String?             // Added for password login
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  sessions      Session[]
  accounts      Account[]

  // Game Relations (Progression linked to User)
  echoesProfile  EchoesPlayer?
  laundryProfile LaundryPlayer?
  sliceItProfile Player?
  vegaProfile    VegaPlayer?
  signalForgeProfile SignalForgePlayer?
  templeOfJoyProfile TempleOfJoySave?
  neonDriftwayProfile NeonDriftwayPlayer?
  synapseStormProfile SynapseStormPlayer?
  
  // Slice-It Library Relations
  uploadedSongs  Song[]        @relation("SongUploader")
  songLikes      SongLike[]
  songRatings    SongRating[]
  songComments   SongComment[]
  songScores     SongLeaderboard[]
  songPlays      SongPlay[]

  // RMH Code Relations
  codeProjects   CodeProject[] @relation("CodeProjects")
  codeFiles      CodeFile[]    @relation("CodeFiles")
  githubToken    UserGitHubToken?

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  expiresAt             DateTime? // Re-added for Better Auth compatibility
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// --- Game Models ---

model EchoesPlayer {
  id            String   @id @default(uuid())
  username      String   @unique
  bestTime      Float    @default(0)
  totalKills    Int      @default(0)
  totalXP       Int      @default(0)
  gamesPlayed   Int      @default(1)
  updatedAt     DateTime @default(now()) @updatedAt

  // Link to Auth User
  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bestTime(sort: Desc)], map: "idx_echoes_best_time")
  @@index([totalKills(sort: Desc)], map: "idx_echoes_kills")
  @@index([totalXP(sort: Desc)], map: "idx_echoes_xp")
}

model LaundryPlayer {
  id            String   @id @default(uuid())
  username      String   @unique
  highScore     Int      @default(0)
  gamesPlayed   Int      @default(1)
  updatedAt     DateTime @default(now()) @updatedAt

  // Link to Auth User
  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([highScore(sort: Desc)], map: "idx_laundry_high_score")
}

// Slice It Player Model
model Player {
  id          String   @id @default(cuid())
  username    String   @unique
  totalScore  Int      @default(0)
  gamesPlayed Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Link to Auth User
  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VegaPlayer {
  id            String   @id @default(uuid())
  username      String   @unique
  highestLoop   Int      @default(1)
  highestLevel  Int      @default(1)
  gamesPlayed   Int      @default(0)
  updatedAt     DateTime @default(now()) @updatedAt

  // Link to Auth User
  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([highestLoop(sort: Desc)], map: "idx_vega_loop")
  @@index([highestLevel(sort: Desc)], map: "idx_vega_level")
}

model SignalForgePlayer {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username      String   @unique
  highScore     Int      @default(0)
  floorReached  Int      @default(1)
  gamesPlayed   Int      @default(1)
  savedRunState Json?
  updatedAt     DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Link to Auth User
  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([highScore(sort: Desc)], map: "idx_signal_forge_high_score")
  @@index([floorReached(sort: Desc)], map: "idx_signal_forge_floor")
}

model TempleOfJoySave {
  id        String   @id @default(cuid())
  userId    String   @unique
  saveData  Json
  updatedAt DateTime @default(now()) @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("temple_of_joy_save")
}

model NeonDriftwayPlayer {
  id            String   @id @default(uuid())
  username      String   @unique
  highScore     Int      @default(0)
  bestDistance   Int      @default(0)
  bestTimeMs    Int      @default(0)
  bestLevel     Int      @default(1)
  gamesPlayed   Int      @default(1)
  updatedAt     DateTime @default(now()) @updatedAt

  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([highScore(sort: Desc)], map: "idx_neon_driftway_high_score")
}

// --- Slice-It Music Library Models ---

model Song {
  id          String   @id @default(cuid())
  title       String
  artist      String
  album       String?
  description String?
  duration    Float
  bpm         Float?
  
  audioUrl    String
  coverUrl    String?
  fileSizeBytes Int?   // bytes of audio file (for 10 GB total storage cap)

  // Audio Analysis Data (JSON for beatmap generation)
  analysisData Json? 

  uploadedBy  String
  uploader    User     @relation("SongUploader", fields: [uploadedBy], references: [id])
  
  isPublic    Boolean  @default(true)
  plays       Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ratings     SongRating[]
  comments    SongComment[]
  scores      SongLeaderboard[]
  likes       SongLike[]
  songPlays   SongPlay[]

  @@index([title])
  @@index([artist])
  @@index([uploadedBy])
}

model SongLike {
  id        String   @id @default(cuid())
  songId    String
  userId    String
  createdAt DateTime @default(now())

  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([songId, userId])
}

model SongRating {
  id        String   @id @default(cuid())
  songId    String
  userId    String
  rating    Int      // 1-5
  createdAt DateTime @default(now())

  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([songId, userId])
}

model SongComment {
  id        String   @id @default(cuid())
  songId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SongLeaderboard {
  id          String   @id @default(cuid())
  songId      String
  userId      String
  score       Int
  maxCombo    Int
  accuracy    Float?
  speedMod    Float    @default(1.0)
  modifiers   Json?
  
  createdAt   DateTime @default(now())

  song        Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([songId, userId], name: "songId_userId")
  @@index([songId, score(sort: Desc)])
}

model SongPlay {
  id           String   @id @default(cuid())
  songId       String
  userId       String
  count        Int      @default(1)
  lastPlayedAt DateTime @default(now())

  song         Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([songId, userId])
}

