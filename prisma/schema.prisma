// ─── RMHark (Feed) Models ─────────────────────────────────────────

model RMHark {
  id        String   @id @default(cuid())
  userId    String
  content   String   @db.Text
  gifUrl    String?  @db.Text
  imageUrls String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ─── Denormalized engagement counters (Phase 1: eventual consistency) ──
  // Maintained transactionally by the like/comment/repost/view routes via
  // atomic increment/decrement, so the feed read path never needs `_count`
  // aggregation. Drift is reconciled by scripts/reconcile-feed-counts.ts.
  likeCount    Int @default(0)
  commentCount Int @default(0)
  repostCount  Int @default(0)
  viewCount    Int @default(0)

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes     RMHarkLike[]
  comments  RMHarkComment[]
  reposts   RMHarkRepost[]
  views     RMHarkView[]
  media     Media[]
  poll      RMHarkPoll?
  bookmarks RMHarkBookmark[]

  // Paid unlock: coins required to view content (null/0 = free)
  unlockPrice Int?
  unlocks     PostUnlock[]

  // Optional community this post belongs to
  communityId String?
  community   Community? @relation(fields: [communityId], references: [id], onDelete: SetNull)

  // Self-relation for reposts (quote-repost displays the original inline)
  originalId String?
  original   RMHark?  @relation("RMHarkReposts", fields: [originalId], references: [id], onDelete: SetNull)
  repostedBy RMHark[] @relation("RMHarkReposts")

  deletedAt      DateTime?
  deletedByAdmin Boolean   @default(false)

  // Audience: who can see this post.
  audience RMHarkAudience @default(PUBLIC)

  // Author-pinned to the top of their profile (one per user, enforced in code).
  pinnedAt DateTime?

  // Edit history: editedAt set on first edit; prior versions stored separately.
  editedAt DateTime?
  edits    RMHarkEdit[]

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  // Composite index backing keyset pagination on (createdAt desc, id desc)
  @@index([createdAt(sort: Desc), id(sort: Desc)])
  @@index([userId, pinnedAt])
  @@map("rmheet")
}

