generator client {
  provider        = "prisma-client-js"
  // Skip engine binary — the pg adapter uses the JS-based query engine
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
}

// User Model (Better Auth)
model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique // Added for username login
  email         String?   @unique
  emailVerified Boolean?
  password      String?             // Added for password login
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  sessions      Session[]
  accounts      Account[]

  // Game Relations (Progression linked to User)
  altairProfile  AltairPlayer?
  altairCoopProfile AltairCoopProfile?
  altairMatchPlayers AltairMatchPlayer[]
  laundryProfile LaundryPlayer?
  sliceItProfile Player?
  vegaProfile    VegaPlayer?
  signalForgeProfile SignalForgePlayer?
  templeOfJoyProfile TempleOfJoySave?
  neonDriftwayProfile NeonDriftwayPlayer?
  synapseStormProfile SynapseStormPlayer?
  rmhboxProfile  RMHboxProfile?
  rmhtypeProfiles RmhTypeProfile[]
  rmhstudyProfile RmhStudyProfile?
  voidBreakerProfile VoidBreakerPlayer?
  lightsOutScores LightsOutScore[]
  versecraftSave  VersecraftSave?
  versecraftProgress VersecraftProgress?
  forestExplorerSave ForestExplorerSave?

  // Slice-It Library Relations
  uploadedSongs  Song[]        @relation("SongUploader")
  songLikes      SongLike[]
  songRatings    SongRating[]
  songComments   SongComment[]
  songScores     SongLeaderboard[]
  songPlays      SongPlay[]

  // RmhTube Relations
  rmhtubeHostedRooms   RmhTubeRoom[]        @relation("RmhTubeHostedRooms")
  rmhtubeRoomMembers   RmhTubeRoomMember[]
  rmhtubeQueueItems    RmhTubeQueueItem[]
  rmhtubePlaylists     RmhTubePlaylist[]
  rmhtubeStats         RmhTubeUserStats?

  // Site Feedback
  feedbacks            Feedback[]

  // RMHark (Feed) Relations
  rmharks              RMHark[]
  rmharkLikes          RMHarkLike[]
  rmharkComments       RMHarkComment[]
  rmharkReposts        RMHarkRepost[]
  rmharkViews          RMHarkView[]
  rmharkCommentLikes   RMHarkCommentLike[]
  rmharkCommentReposts RMHarkCommentRepost[]
  rmharkCommentViews   RMHarkCommentView[]

  // Profile & Social
  profile              UserProfile?
  followers            Follow[]    @relation("UserFollowing")
  following            Follow[]    @relation("UserFollowers")

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  expiresAt             DateTime? // Re-added for Better Auth compatibility
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// --- Game Models ---

model AltairPlayer {
  id                String   @id @default(uuid())
  username          String   @unique
  bestTime          Float    @default(0)
  totalKills        Int      @default(0)
  totalXP           Int      @default(0)
  totalGold         Int      @default(0)
  totalTimeSurvived Float    @default(0)
  gamesPlayed       Int      @default(1)
  updatedAt         DateTime @default(now()) @updatedAt

  // Link to Auth User
  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bestTime(sort: Desc)], map: "idx_altair_best_time")
  @@index([totalKills(sort: Desc)], map: "idx_altair_kills")
  @@index([totalXP(sort: Desc)], map: "idx_altair_xp")
  @@index([totalGold(sort: Desc)], map: "idx_altair_gold")
  @@index([totalTimeSurvived(sort: Desc)], map: "idx_altair_survival")
}

model LaundryPlayer {
  id            String   @id @default(uuid())
  username      String   @unique
  highScore     Int      @default(0)
  gamesPlayed   Int      @default(1)
  updatedAt     DateTime @default(now()) @updatedAt

  // Link to Auth User
  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([highScore(sort: Desc)], map: "idx_laundry_high_score")
}

model LightsOutScore {
  id        String   @id @default(cuid())
  userId    String
  dateKey   String   // YYYY-MM-DD
  moves     Int      @default(0)
  hintUsed  Boolean  @default(false)
  dnf       Boolean  @default(false)
  createdAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
  @@index([dateKey, moves(sort: Asc)])
  @@index([dateKey, dnf(sort: Asc)])
  @@map("lights_out_score")
}

// Slice It Player Model
model Player {
  id          String   @id @default(cuid())
  username    String   @unique
  totalScore  Int      @default(0)
  gamesPlayed Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Link to Auth User
  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VegaPlayer {
  id            String   @id @default(uuid())
  username      String   @unique
  highestLoop   Int      @default(1)
  highestLevel  Int      @default(1)
  gamesPlayed   Int      @default(0)
  updatedAt     DateTime @default(now()) @updatedAt

  // Link to Auth User
  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([highestLoop(sort: Desc)], map: "idx_vega_loop")
  @@index([highestLevel(sort: Desc)], map: "idx_vega_level")
}

model SignalForgePlayer {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username      String   @unique
  highScore     Int      @default(0)
  floorReached  Int      @default(1)
  gamesPlayed   Int      @default(1)
  savedRunState Json?
  updatedAt     DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Link to Auth User
  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([highScore(sort: Desc)], map: "idx_signal_forge_high_score")
  @@index([floorReached(sort: Desc)], map: "idx_signal_forge_floor")
}

model TempleOfJoySave {
  id        String   @id @default(cuid())
  userId    String   @unique
  saveData  Json
  updatedAt DateTime @default(now()) @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("temple_of_joy_save")
}

model NeonDriftwayPlayer {
  id            String   @id @default(uuid())
  username      String   @unique
  highScore     Int      @default(0)
  bestDistance   Int      @default(0)
  bestTimeMs    Int      @default(0)
  bestLevel     Int      @default(1)
  gamesPlayed   Int      @default(1)
  updatedAt     DateTime @default(now()) @updatedAt

  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([highScore(sort: Desc)], map: "idx_neon_driftway_high_score")
}

model VoidBreakerPlayer {
  id            String   @id @default(uuid())
  username      String   @unique
  highScore     Int      @default(0)
  bestWave      Int      @default(0)
  totalKills    Int      @default(0)
  bestTimeMs    Int      @default(0)
  gamesPlayed   Int      @default(1)
  updatedAt     DateTime @default(now()) @updatedAt

  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([highScore(sort: Desc)], map: "idx_void_breaker_high_score")
}

// --- Slice-It Music Library Models ---

model Song {
  id          String   @id @default(cuid())
  title       String
  artist      String
  album       String?
  description String?
  duration    Float
  bpm         Float?
  
  audioUrl    String
  coverUrl    String?
  fileSizeBytes Int?   // bytes of audio file (for 10 GB total storage cap)

  // Audio Analysis Data (JSON for beatmap generation)
  analysisData Json? 

  uploadedBy  String
  uploader    User     @relation("SongUploader", fields: [uploadedBy], references: [id])
  
  isPublic    Boolean  @default(true)
  plays       Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ratings     SongRating[]
  comments    SongComment[]
  scores      SongLeaderboard[]
  likes       SongLike[]
  songPlays   SongPlay[]

  @@index([title])
  @@index([artist])
  @@index([uploadedBy])
}

model SongLike {
  id        String   @id @default(cuid())
  songId    String
  userId    String
  createdAt DateTime @default(now())

  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([songId, userId])
}

model SongRating {
  id        String   @id @default(cuid())
  songId    String
  userId    String
  rating    Int      // 1-5
  createdAt DateTime @default(now())

  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([songId, userId])
}

model SongComment {
  id        String   @id @default(cuid())
  songId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SongLeaderboard {
  id          String   @id @default(cuid())
  songId      String
  userId      String
  score       Int
  maxCombo    Int
  accuracy    Float?
  speedMod    Float    @default(1.0)
  modifiers   Json?
  
  createdAt   DateTime @default(now())

  song        Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([songId, userId], name: "songId_userId")
  @@index([songId, score(sort: Desc)])
}

model SongPlay {
  id           String   @id @default(cuid())
  songId       String
  userId       String
  count        Int      @default(1)
  lastPlayedAt DateTime @default(now())

  song         Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([songId, userId])
}

model SynapseStormPlayer {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  highScore      Int      @default(0)
  puzzlesSolved  Int      @default(0)
  maxCombo       Int      @default(0)
  peakDifficulty Float    @default(1)
  totalTime      Float    @default(0)
  updatedAt      DateTime @default(now()) @updatedAt

  @@map("synapse_storm_player")
  @@index([highScore(sort: Desc)])
}

// ─── Synapse Storm Multiplayer ───

enum SSLobbyStatus {
  WAITING
  IN_MATCH
  CLOSED
}

enum SSMatchStatus {
  RUNNING
  FINISHED
}

model SSLobby {
  id         String        @id @default(cuid())
  code       String        @unique
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  status     SSLobbyStatus @default(WAITING)
  hostUserId String

  members SSLobbyMember[]
  matches SSMatch[]

  @@map("ss_lobby")
}

model SSLobbyMember {
  id          String   @id @default(cuid())
  lobbyId     String
  userId      String
  displayName String
  joinedAt    DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  isReady     Boolean  @default(false)
  isHost      Boolean  @default(false)

  lobby SSLobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, userId])
  @@index([lobbyId])
  @@map("ss_lobby_member")
}

model SSMatch {
  id        String        @id @default(cuid())
  lobbyId   String
  seed      Int
  startAt   DateTime
  endAt     DateTime?
  status    SSMatchStatus @default(RUNNING)
  createdAt DateTime      @default(now())

  lobby   SSLobby         @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  players SSPlayerMatch[]

  @@index([lobbyId])
  @@map("ss_match")
}

model SSPlayerMatch {
  id            String    @id @default(cuid())
  matchId       String
  lobbyId       String
  userId        String
  displayName   String
  score         Int       @default(0)
  maxCombo      Int       @default(0)
  puzzlesSolved Int       @default(0)
  puzzlesMissed Int       @default(0)
  finishedAt    DateTime?
  lastUpdateAt  DateTime  @default(now())

  match SSMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@index([matchId])
  @@index([lobbyId])
  @@map("ss_player_match")
}
// --- RMHbox Models ---

model RMHboxProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalGamesPlayed Int      @default(0)
  totalWins        Int      @default(0)
  totalScore       Int      @default(0)
  totalPlayTimeMs  Int      @default(0)
  minigameStats    Json     @default("{}")
  currentWinStreak Int      @default(0)
  bestWinStreak    Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  matches          RMHboxMatchPlayer[]

  @@index([totalWins(sort: Desc)])
  @@index([totalScore(sort: Desc)])
  @@map("rmhbox_profile")
}

model RMHboxMatch {
  id            String    @id @default(cuid())
  minigameId    String
  lobbyId       String
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  durationMs    Int?
  winnerUserId  String?
  playerCount   Int
  gameLog       Json?
  results       Json
  players       RMHboxMatchPlayer[]

  @@index([minigameId])
  @@index([startedAt(sort: Desc)])
  @@index([lobbyId])
  @@map("rmhbox_match")
}

model RMHboxMatchPlayer {
  id        String   @id @default(cuid())
  matchId   String
  match     RMHboxMatch   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  profileId String
  profile   RMHboxProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  userId    String
  userName  String
  rank      Int
  score     Int
  wasWinner Boolean  @default(false)
  stats     Json     @default("{}")
  createdAt DateTime @default(now())

  @@unique([matchId, userId])
  @@index([profileId])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("rmhbox_match_player")
}

// ─── RmhTube Models ─────────────────────────────────────────

model RmhTubeRoom {
  id              String    @id                    // 6-char room code
  name            String?
  hostId          String
  isPublic        Boolean   @default(true)
  password        String?
  maxMembers      Int       @default(20)
  allowMemberQueue Boolean  @default(true)
  allowMemberSkip  Boolean  @default(true)
  autoPlay        Boolean   @default(true)
  scheduledFor    DateTime?
  description     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  closedAt        DateTime?

  host     User                  @relation("RmhTubeHostedRooms", fields: [hostId], references: [id])
  members  RmhTubeRoomMember[]
  messages RmhTubeChatMessage[]
  queue    RmhTubeQueueItem[]

  @@index([isPublic, closedAt])
  @@map("rmhtube_room")
}

model RmhTubeRoomMember {
  id       String    @id @default(cuid())
  roomId   String
  userId   String
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  room RmhTubeRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
  @@map("rmhtube_room_member")
}

model RmhTubeChatMessage {
  id             String   @id @default(cuid())
  roomId         String
  userId         String
  userName       String
  content        String
  replyToId      String?
  createdAt      DateTime @default(now())

  room    RmhTubeRoom         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  replyTo RmhTubeChatMessage? @relation("ChatReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies RmhTubeChatMessage[] @relation("ChatReplies")

  @@index([roomId, createdAt])
  @@map("rmhtube_chat_message")
}

model RmhTubeQueueItem {
  id           String    @id @default(cuid())
  roomId       String
  url          String
  mediaType    String
  title        String
  duration     Int?
  thumbnailUrl String?
  addedById    String
  addedByName  String
  position     Int
  playedAt     DateTime?
  createdAt    DateTime  @default(now())

  room    RmhTubeRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  addedBy User        @relation(fields: [addedById], references: [id])

  @@index([roomId, position])
  @@map("rmhtube_queue_item")
}

model RmhTubePlaylist {
  id        String   @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User                  @relation(fields: [userId], references: [id])
  items RmhTubePlaylistItem[]

  @@index([userId])
  @@map("rmhtube_playlist")
}

model RmhTubePlaylistItem {
  id           String  @id @default(cuid())
  playlistId   String
  url          String
  mediaType    String
  title        String
  duration     Int?
  thumbnailUrl String?
  position     Int

  playlist RmhTubePlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([playlistId, position])
  @@map("rmhtube_playlist_item")
}

model RmhTubeUserStats {
  userId              String   @id
  totalWatchTimeMinutes Int    @default(0)
  videosWatched       Int      @default(0)
  roomsCreated        Int      @default(0)
  roomsJoined         Int      @default(0)
  messagesSent        Int      @default(0)
  reactionsUsed       Int      @default(0)
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("rmhtube_user_stats")
}

// ─── RMH Type Models ───────────────────────────────────────

model RmhTypeProfile {
  id               String   @id @default(cuid())
  userId           String
  difficulty       String   @default("medium")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalGamesPlayed Int      @default(0)
  totalWins        Int      @default(0)
  bestWpm          Float    @default(0)
  bestWpmAccuracy  Float    @default(0)
  avgWpm           Float    @default(0)
  bestAccuracy     Float    @default(0)
  avgAccuracy      Float    @default(0)
  totalCharsTyped  Int      @default(0)
  totalTimeMs      Int      @default(0)
  currentStreak    Int      @default(0)
  bestStreak       Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  matches          RmhTypeMatchPlayer[]

  @@unique([userId, difficulty])
  @@index([difficulty, bestWpm(sort: Desc)])
  @@index([totalWins(sort: Desc)])
  @@map("rmhtype_profile")
}

model RmhTypeMatch {
  id            String    @id @default(cuid())
  roomId        String
  difficulty    String
  passageId     String
  passageLength String
  rounds        Int
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  durationMs    Int?
  winnerUserId  String?
  playerCount   Int
  isSolo        Boolean   @default(false)
  results       Json
  players       RmhTypeMatchPlayer[]

  @@index([startedAt(sort: Desc)])
  @@index([winnerUserId])
  @@map("rmhtype_match")
}

model RmhTypeMatchPlayer {
  id        String         @id @default(cuid())
  matchId   String
  match     RmhTypeMatch   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  profileId String
  profile   RmhTypeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  userId    String
  userName  String
  rank      Int
  wpm       Float
  accuracy  Float
  timeMs    Int
  score     Int
  wasWinner Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([matchId, userId])
  @@index([profileId])
  @@index([userId])
  @@index([wpm(sort: Desc)])
  @@map("rmhtype_match_player")
}

// ─── RMH Study Models ──────────────────────────────────────

model RmhStudyProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalFocusTimeMs  BigInt    @default(0)
  sessionsCompleted Int       @default(0)
  currentStreak     Int       @default(0)
  longestStreak     Int       @default(0)
  lastStudyDate     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  sessions          RmhStudySession[]

  @@index([totalFocusTimeMs(sort: Desc)])
  @@index([sessionsCompleted(sort: Desc)])
  @@index([currentStreak(sort: Desc)])
  @@map("rmhstudy_profile")
}

model RmhStudySession {
  id            String          @id @default(cuid())
  profileId     String
  profile       RmhStudyProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  userId        String
  roomId        String?
  focusTimeMs   Int
  breakTimeMs   Int
  sessionsInRun Int
  startedAt     DateTime        @default(now())
  endedAt       DateTime?

  @@index([profileId])
  @@index([userId])
  @@index([startedAt(sort: Desc)])
  @@map("rmhstudy_session")
}

// ─── Versecraft (Poetry VN) ─────────────────────────────────────────

model VersecraftSave {
  id        String   @id @default(cuid())
  userId    String   @unique
  saveData  Json
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("versecraft_save")
}

model VersecraftProgress {
  id                String   @id @default(cuid())
  userId            String   @unique
  completedChapters Json     @default("[]")
  unlockedEndings   Json     @default("[]")
  completedRoutes   Json     @default("[]")
  totalPoemsWritten Int      @default(0)
  totalPlaytime     Int      @default(0)
  updatedAt         DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("versecraft_progress")
}

// ─── Forest Explorer (Story Mode) ──────────────────────────────────

model ForestExplorerSave {
  id        String   @id @default(cuid())
  userId    String   @unique
  saveData  Json
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("forest_explorer_save")
}

// ─── Site Feedback ──────────────────────────────────────────────────
model Feedback {
  id        String   @id @default(cuid())
  category  String
  message   String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("feedback")
}

// ─── Altair Multiplayer (Co-op) Models ────────────────────────

model AltairCoopProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalCoopRuns      Int      @default(0)
  totalCoopWins      Int      @default(0)
  totalRevivesGiven  Int      @default(0)
  totalRevivesReceived Int    @default(0)
  totalCoopKills     Int      @default(0)
  totalCoopCoins     Int      @default(0)
  favoriteClassId    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([totalCoopWins(sort: Desc)])
  @@index([totalRevivesGiven(sort: Desc)])
  @@map("altair_coop_profile")
}

model AltairMatch {
  id             String    @id @default(cuid())
  lobbyId        String
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  durationMs     Int?
  playerCount    Int
  doubleTime     Boolean   @default(false)
  victory        Boolean   @default(false)
  sharedKills    Int       @default(0)
  bossesDefeated String[]  @default([])
  results        Json?
  players        AltairMatchPlayer[]

  @@index([startedAt(sort: Desc)])
  @@index([lobbyId])
  @@map("altair_match")
}

model AltairMatchPlayer {
  id              String      @id @default(cuid())
  matchId         String
  match           AltairMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userName        String
  classId         String
  slot            Int
  finalLevel      Int         @default(1)
  kills           Int         @default(0)
  coinsEarned     Int         @default(0)
  timeSurvived    Float       @default(0)
  wasDowned       Boolean     @default(false)
  wasRevived      Boolean     @default(false)
  revivesGiven    Int         @default(0)
  wasAliveAtEnd   Boolean     @default(true)
  stats           Json        @default("{}")
  createdAt       DateTime    @default(now())

  @@unique([matchId, userId])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("altair_match_player")
}

// ─── RMHark (Feed) Models ─────────────────────────────────────────

model RMHark {
  id        String   @id @default(cuid())
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes     RMHarkLike[]
  comments  RMHarkComment[]
  reposts   RMHarkRepost[]
  views     RMHarkView[]

  // Self-relation for reposts (quote-repost displays the original inline)
  originalId String?
  original   RMHark?  @relation("RMHarkReposts", fields: [originalId], references: [id], onDelete: SetNull)
  repostedBy RMHark[] @relation("RMHarkReposts")

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("rmheet")
}

model RMHarkLike {
  id        String   @id @default(cuid())
  rmheetId  String
  userId    String
  createdAt DateTime @default(now())

  rmhark    RMHark   @relation(fields: [rmheetId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([rmheetId, userId])
  @@map("rmheet_like")
}

model RMHarkComment {
  id        String   @id @default(cuid())
  rmheetId  String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rmhark    RMHark   @relation(fields: [rmheetId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Optional threaded replies
  parentId  String?
  parent    RMHarkComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies   RMHarkComment[] @relation("CommentReplies")

  // Engagement
  likes     RMHarkCommentLike[]
  reposts   RMHarkCommentRepost[]
  views     RMHarkCommentView[]

  @@index([rmheetId, createdAt(sort: Desc)])
  @@map("rmheet_comment")
}

model RMHarkCommentLike {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment   RMHarkComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@map("rmheet_comment_like")
}

model RMHarkCommentRepost {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment   RMHarkComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@map("rmheet_comment_repost")
}

model RMHarkCommentView {
  id        String   @id @default(cuid())
  commentId String
  userId    String?
  ipHash    String?
  createdAt DateTime @default(now())

  comment   RMHarkComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@unique([commentId, ipHash])
  @@index([commentId])
  @@map("rmheet_comment_view")
}

model RMHarkRepost {
  id        String   @id @default(cuid())
  rmheetId  String
  userId    String
  createdAt DateTime @default(now())

  rmhark    RMHark   @relation(fields: [rmheetId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([rmheetId, userId])
  @@map("rmheet_repost")
}

model RMHarkView {
  id        String   @id @default(cuid())
  rmheetId  String
  userId    String?
  ipHash    String?
  createdAt DateTime @default(now())

  rmhark    RMHark   @relation(fields: [rmheetId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([rmheetId, userId])
  @@unique([rmheetId, ipHash])
  @@index([rmheetId])
  @@map("rmheet_view")
}

// ─── User Profile (Social) ──────────────────────────────────────

model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName         String?  @db.VarChar(50)
  customImage         String?
  customImageSizeBytes Int?
  bio       String?  @db.VarChar(160)
  location  String?  @db.VarChar(100)
  website   String?  @db.VarChar(200)
  showLikes Boolean  @default(false)
  profileSongSpotifyId  String?  @db.VarChar(50)
  profileSongTitle      String?  @db.VarChar(200)
  profileSongArtist     String?  @db.VarChar(200)
  profileSongPreviewUrl String?  @db.VarChar(500)
  profileSongAlbumArt   String?  @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_profile")
}

// ─── News ─────────────────────────────────────────────────────────

enum NewsStatus {
  STAGING
  PUBLISHED
}

model NewsArticle {
  id              String     @id @default(cuid())
  slug            String     @unique
  title           String
  date            String
  description     String     @db.Text
  content         String     @db.Text
  category        String
  tags            String[]
  featured        Boolean    @default(false)
  sourceTitle     String
  sourceUrl       String
  sourcePublisher String
  sourceDate      String?
  image           String?
  status          NewsStatus @default(PUBLISHED)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([status, date(sort: Desc)])
  @@index([category])
  @@index([slug])
  @@map("news_article")
}

// ─── Follow Relation ─────────────────────────────────────────────

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follow")
}
