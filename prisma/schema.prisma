  slug            String     @unique
  title           String
  date            String
  description     String     @db.Text
  content         String     @db.Text
  category        String
  tags            String[]
  featured        Boolean    @default(false)
  sourceTitle     String
  sourceUrl       String
  sourcePublisher String
  sourceDate      String?
  image           String?
  status          NewsStatus @default(PUBLISHED)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

