model LadderAlert {
  id      String             @id @default(cuid())
  userId  String
  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId   String
  job     LadderJob          @relation(fields: [jobId], references: [id], onDelete: Cascade)
