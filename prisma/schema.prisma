// ─── Synapse Storm Multiplayer ───

enum SSLobbyStatus {
  WAITING
  IN_MATCH
  CLOSED
}

enum SSMatchStatus {
  RUNNING
  FINISHED
}

model SSLobby {
  id         String        @id @default(cuid())
  code       String        @unique
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  status     SSLobbyStatus @default(WAITING)
  hostUserId String

  members SSLobbyMember[]
  matches SSMatch[]

  @@map("ss_lobby")
}

model SSLobbyMember {
  id          String   @id @default(cuid())
  lobbyId     String
  userId      String
  displayName String
  joinedAt    DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  isReady     Boolean  @default(false)
  isHost      Boolean  @default(false)

  lobby SSLobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, userId])
  @@index([lobbyId])
  @@map("ss_lobby_member")
}

model SSMatch {
  id        String        @id @default(cuid())
  lobbyId   String
  seed      Int
  startAt   DateTime
  endAt     DateTime?
  status    SSMatchStatus @default(RUNNING)
  createdAt DateTime      @default(now())

  lobby   SSLobby         @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  players SSPlayerMatch[]

  @@index([lobbyId])
  @@map("ss_match")
}

