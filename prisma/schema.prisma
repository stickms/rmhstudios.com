generator client {
  provider        = "prisma-client-js"
  // Skip engine binary — the pg adapter uses the JS-based query engine
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
}

// User Model (Better Auth)
model User {
  id            String   @id @default(cuid())
  name          String?
  username        String?   @unique // Added for username login
  handle          String?   @unique // Unique user handle for @mentions and URLs
  handleChangedAt DateTime? // Last time the handle was changed (2-week cooldown)
  email           String?   @unique
  emailVerified   Boolean?
  password        String?   // Added for password login
  image           String?
  stripeCustomerId String?  // Stripe customer id (set by @better-auth/stripe on signup)
  isAdmin         Boolean   @default(false)
  isVerified      Boolean   @default(false)
  // Moderation: temporary/permanent ban (null = not banned)
  bannedUntil     DateTime?
  banReason       String?   @db.VarChar(500)
  // Presence: last heartbeat from an active client (for "online now")
  lastSeenAt      DateTime?
  // ─── RMHark AI bot users (generated + driven by the bot-worker) ──
  isBot           Boolean   @default(false) // synthetic account created by the bot-worker
  botPersona      String?   @db.Text         // private prompt seed describing the bot's posting "theme"
  botLastPostAt   DateTime?                   // last time the worker posted as this bot (pacing)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sessions Session[]
  accounts Account[]

  // Game Relations (Progression linked to User)
  altairProfile       AltairPlayer?
  altairMetaProgress  AltairMetaProgress?
  altairCoopProfile   AltairCoopProfile?
  altairMatchPlayers  AltairMatchPlayer[]
  laundryProfile      LaundryPlayer?
  sliceItProfile      Player?
  vegaProfile         VegaPlayer?
  signalForgeProfile  SignalForgePlayer?
  templeOfJoyProfile  TempleOfJoySave?
  neonDriftwayProfile NeonDriftwayPlayer?
  synapseStormProfile SynapseStormPlayer?
  rmhboxProfile       RMHboxProfile?
  rmhtypeProfiles     RmhTypeProfile[]
  libraryUploads      LibraryDocument[] @relation("LibraryUploader")
  libraryCollections  LibraryCollection[] @relation("LibraryCollectionOwner")
  /// Per-user library upload quota override (null → the default cap). Raised by
  /// an admin when approving a quota appeal.
  libraryUploadQuota  Int?
  libraryQuotaRequests LibraryQuotaRequest[] @relation("LibraryQuotaRequests")
  rmhstudyProfile     RmhStudyProfile?
  voidBreakerProfile  VoidBreakerPlayer?
  dailyPuzzleScores   DailyPuzzleScore[]
  versecraftSave      VersecraftSave?
  versecraftProgress  VersecraftProgress?
  forestExplorerSave  ForestExplorerSave?
  dreamRiftProfile    DreamRiftPlayer?
  dreamRiftCoopRuns   DreamRiftCoopRun[]
  farmingSimFarm      FarmingSimFarm?

  // Slice-It Library Relations
  uploadedSongs Song[]            @relation("SongUploader")
  songLikes     SongLike[]
  songRatings   SongRating[]
  songComments  SongComment[]
  songScores    SongLeaderboard[]
  songPlays     SongPlay[]

  // RmhTube Relations
  rmhtubeHostedRooms RmhTubeRoom[]       @relation("RmhTubeHostedRooms")
  rmhtubeRoomMembers RmhTubeRoomMember[]
  rmhtubeQueueItems  RmhTubeQueueItem[]
  rmhtubePlaylists   RmhTubePlaylist[]
  rmhtubeStats       RmhTubeUserStats?

  // ─── RMHMusic ──────────────────────────────────────────────────
  rmhMusicHostedRooms  RmhMusicRoom[]        @relation("RmhMusicHostedRooms")
  rmhMusicRoomMembers  RmhMusicRoomMember[]  @relation("RmhMusicRoomMembers")
  rmhMusicQueueItems   RmhMusicQueueItem[]   @relation("RmhMusicQueueItems")
  rmhMusicChatMessages RmhMusicChatMessage[] @relation("RmhMusicChatMessages")

  // Site Feedback
  feedbacks Feedback[]

  // RMHark (Feed) Relations
  rmharks              RMHark[]
  rmharkLikes          RMHarkLike[]
  rmharkComments       RMHarkComment[]
  rmharkReposts        RMHarkRepost[]
  rmharkViews          RMHarkView[]
  rmharkCommentLikes   RMHarkCommentLike[]
  rmharkCommentReposts RMHarkCommentRepost[]
  rmharkCommentViews   RMHarkCommentView[]
  rmharkPollVotes      RMHarkPollVote[]
  announcementPollVotes FeedAnnouncementPollVote[]

  // Profile & Social
  profile   UserProfile?
  followers Follow[]     @relation("UserFollowing")
  following Follow[]     @relation("UserFollowers")

  // Notifications
  notifications      Notification[] @relation("UserNotifications")
  notificationsSent  Notification[] @relation("UserNotificationActor")

  // Engagement: bookmarks, achievements, daily streak
  bookmarks    RMHarkBookmark[]
  achievements UserAchievement[]
  dailyStreak  DailyStreak?
  postUnlocks  PostUnlock[]

  // Communities created + memberships
  communitiesCreated Community[]       @relation("CommunityCreator")
  communityMembers   CommunityMember[]
  communityAnnouncements CommunityAnnouncement[] @relation("CommunityAnnouncementAuthor")

  // Progression: quests + battle-pass season progress
  quests         UserQuest[]
  seasonProgress UserSeasonProgress[]

  // Composer: saved drafts + scheduled posts
  scheduledPosts ScheduledPost[]

  // Daily coin wheel spins
  wheelSpins DailyWheelSpin[]

  // Coin staking (interest-bearing vault)
  coinStake CoinStake?


  // Creator storefront
  storefrontProducts  StorefrontProduct[]  @relation("StorefrontCreator")
  storefrontPurchases StorefrontPurchase[] @relation("StorefrontBuyer")

  // AI persona chatbots
  aiPersonas        AiPersona[]        @relation("PersonaOwner")
  aiPersonaMessages AiPersonaMessage[]

  // Build marketplace unlocks
  buildUnlocks BuildUnlock[]

  // Ranked play: ELO ratings + challenges
  eloRatings            EloRating[]
  challengesIssued      RankedChallenge[] @relation("ChallengeChallenger")
  challengesReceived    RankedChallenge[] @relation("ChallengeOpponent")

  // Gifted (coin-funded) memberships
  giftMembershipsReceived GiftMembership[] @relation("GiftRecipient")
  giftMembershipsSent     GiftMembership[] @relation("GiftGifter")

  // Group DMs
  groupChatsOwned   GroupChat[]       @relation("GroupOwner")
  groupMemberships  GroupChatMember[]
  groupMessages     GroupMessage[]
  groupPollVotes    GroupPollVote[]

  // RMHStudy flashcards
  flashcardDecks   FlashcardDeck[]
  flashcardReviews FlashcardReview[]

  // RMHTube channel subscriptions
  rmhtubeSubscriptions RmhTubeSubscription[] @relation("TubeSubscriber")
  rmhtubeSubscribers   RmhTubeSubscription[] @relation("TubeChannel")

  // RMHMusic "guess the song" game
  musicPuzzles       MusicGuessPuzzle[]
  musicGuessAttempts MusicGuessAttempt[]

  // Developer API keys + one-time promo claims
  developerApiKeys DeveloperApiKey[]
  promoClaims      PromoClaim[]

  // Economy: shop inventory, coin ledger (tips/gifts)
  inventory       UserInventory[]
  coinsSent       CoinTransaction[] @relation("CoinSender")
  coinsReceived   CoinTransaction[] @relation("CoinRecipient")

  // Prediction markets: created markets + open positions
  predictionsCreated  Prediction[]         @relation("PredictionCreator")
  predictionPositions PredictionPosition[] @relation("PredictionPositions")

  // Admin-authored feed announcements
  feedAnnouncements FeedAnnouncement[]

  // Admin moderation: audit log entries authored, strikes received/issued
  auditLogs      AdminAuditLog[] @relation("AuditAdmin")
  strikes        UserStrike[]    @relation("StrikeUser")
  strikesIssued  UserStrike[]    @relation("StrikeAdmin")

  // Moderation (reports filed / received, blocks & mutes)
  reportsFiled    ContentReport[] @relation("ReportReporter")
  reportsResolved ContentReport[] @relation("ReportResolver")
  blocksMade      UserBlock[]     @relation("BlockBlocker")
  blocksReceived  UserBlock[]     @relation("BlockBlocked")
  mutesMade       UserMute[]      @relation("MuteMuter")
  mutesReceived   UserMute[]      @relation("MuteMuted")

  // Direct Messages
  conversationsAsOne Conversation[]  @relation("ConversationParticipantOne")
  conversationsAsTwo Conversation[]  @relation("ConversationParticipantTwo")
  directMessages     DirectMessage[]

  // rmhcode & User Builds
  rmhCodeTokens RmhCodeToken[]
  userBuilds    UserBuild[]
  buildLikes    BuildLike[]
  buildComments BuildComment[]
  buildViews    BuildView[]

  // ─── Doctrine Engine (RMH Strategies) ─────────────────────────
  doctrineTier          String    @default("PUBLIC") // PUBLIC | INSIDER | OPERATOR
  doctrineTierChangedAt DateTime?
  doctrineTimezone      String    @default("America/New_York")
  doctrineRecruitedById String?
  doctrineRecruitedBy   User?                         @relation("DoctrineRecruitment", fields: [doctrineRecruitedById], references: [id])
  doctrineRecruits      User[]                        @relation("DoctrineRecruitment")
  doctrineReputation          DoctrineReputation?
  doctrinePuzzleSubmissions   DoctrinePuzzleSubmission[]
  doctrinePuzzleReplays       DoctrinePuzzleReplay[]
  doctrineSafehouseAccessLogs DoctrineAccessLog[]
  doctrineIncidentReports     DoctrineIncidentReport[]
  doctrineReactions           DoctrineReaction[]
  doctrineRecruitmentCodes    DoctrineRecruitmentCode[]
  doctrineSahurParticipations DoctrineSahurParticipation[]

  // ─── RMH Rideshare ────────────────────────────────────────────
  rideshareDriver       RideshareDriver?
  rideshareApplications RideshareDriver[] @relation("RideshareApplicationReviewer")
  ridesRequested        Ride[]            @relation("RideRider")
  ridesDriven           Ride[]            @relation("RideDriver")
  rideMessages          RideMessage[]
  rideSavedPlaces       RideSavedPlace[]

  media         Media[]

  @@index([isBot])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  expiresAt             DateTime? // Re-added for Better Auth compatibility
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([providerId, accountId])
  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// --- Blog Models ---

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  date        String
  description String
  image       String?
  tags        String[]
  content     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date(sort: Desc)])
  @@map("blog_post")
}

// --- Game Models ---

model AltairPlayer {
  id                String   @id @default(uuid())
  username          String   @unique
  bestTime          Float    @default(0)
  totalKills        Int      @default(0)
  totalXP           Int      @default(0)
  totalGold         Int      @default(0)
  totalTimeSurvived Float    @default(0)
  gamesPlayed       Int      @default(1)
  updatedAt         DateTime @default(now()) @updatedAt

  // Link to Auth User
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bestTime(sort: Desc)], map: "idx_altair_best_time")
  @@index([totalKills(sort: Desc)], map: "idx_altair_kills")
  @@index([totalXP(sort: Desc)], map: "idx_altair_xp")
  @@index([totalGold(sort: Desc)], map: "idx_altair_gold")
  @@index([totalTimeSurvived(sort: Desc)], map: "idx_altair_survival")
}

model LaundryPlayer {
  id          String   @id @default(uuid())
  username    String   @unique
  highScore   Int      @default(0)
  gamesPlayed Int      @default(1)
  updatedAt   DateTime @default(now()) @updatedAt

  // Link to Auth User
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([highScore(sort: Desc)], map: "idx_laundry_high_score")
}

// Daily Puzzle Score — generic leaderboard for all daily puzzles including lights-out
model DailyPuzzleScore {
  id        String   @id @default(cuid())
  userId    String
  gameMode  String   // lights-out | alibi | spectrum | outcast | chainlink | impostor
  dateKey   String   // YYYY-MM-DD
  score     Int      @default(0)   // points (higher = better) for most games
  moves     Int?                    // lights-out: move count (lower = better)
  hintUsed  Boolean? @default(false) // lights-out: whether hints were used
  dnf         Boolean? @default(false) // lights-out: did not finish
  resultJson  Json?                    // game-specific result data
  timeSeconds Int?                     // time taken (for timed games)
  createdAt   DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameMode, dateKey])
  @@index([gameMode, dateKey, score(sort: Desc)])
  @@index([gameMode, dateKey, moves(sort: Asc)])
  @@map("daily_puzzle_score")
}

// Slice It Player Model
model Player {
  id          String   @id @default(cuid())
  username    String   @unique
  totalScore  Int      @default(0)
  gamesPlayed Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Link to Auth User
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VegaPlayer {
  id           String   @id @default(uuid())
  username     String   @unique
  highestLoop  Int      @default(1)
  highestLevel Int      @default(1)
  gamesPlayed  Int      @default(0)
  updatedAt    DateTime @default(now()) @updatedAt

  // Link to Auth User
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([highestLoop(sort: Desc)], map: "idx_vega_loop")
  @@index([highestLevel(sort: Desc)], map: "idx_vega_level")
}

model SignalForgePlayer {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username      String   @unique
  highScore     Int      @default(0)
  floorReached  Int      @default(1)
  gamesPlayed   Int      @default(1)
  savedRunState Json?
  updatedAt     DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Link to Auth User
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([highScore(sort: Desc)], map: "idx_signal_forge_high_score")
  @@index([floorReached(sort: Desc)], map: "idx_signal_forge_floor")
}

model TempleOfJoySave {
  id        String   @id @default(cuid())
  userId    String   @unique
  saveData  Json
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("temple_of_joy_save")
}

model NeonDriftwayPlayer {
  id           String   @id @default(uuid())
  username     String   @unique
  highScore    Int      @default(0)
  bestDistance Int      @default(0)
  bestTimeMs   Int      @default(0)
  bestLevel    Int      @default(1)
  gamesPlayed  Int      @default(1)
  updatedAt    DateTime @default(now()) @updatedAt

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([highScore(sort: Desc)], map: "idx_neon_driftway_high_score")
}

model VoidBreakerPlayer {
  id          String   @id @default(uuid())
  username    String   @unique
  highScore   Int      @default(0)
  bestWave    Int      @default(0)
  totalKills  Int      @default(0)
  bestTimeMs  Int      @default(0)
  gamesPlayed Int      @default(1)
  updatedAt   DateTime @default(now()) @updatedAt

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([highScore(sort: Desc)], map: "idx_void_breaker_high_score")
}

// --- Slice-It Music Library Models ---

model Song {
  id          String  @id @default(cuid())
  title       String
  artist      String
  album       String?
  description String?
  duration    Float
  bpm         Float?

  audioUrl      String
  coverUrl      String?
  fileSizeBytes Int? // bytes of audio file (for 10 GB total storage cap)

  // Audio Analysis Data (JSON for beatmap generation)
  analysisData Json?

  uploadedBy String
  uploader   User   @relation("SongUploader", fields: [uploadedBy], references: [id])

  isPublic Boolean @default(true)
  plays    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ratings   SongRating[]
  comments  SongComment[]
  scores    SongLeaderboard[]
  likes     SongLike[]
  songPlays SongPlay[]

  @@index([title])
  @@index([artist])
  @@index([uploadedBy])
}

model SongLike {
  id        String   @id @default(cuid())
  songId    String
  userId    String
  createdAt DateTime @default(now())

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([songId, userId])
}

model SongRating {
  id        String   @id @default(cuid())
  songId    String
  userId    String
  rating    Int // 1-5
  createdAt DateTime @default(now())

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([songId, userId])
}

model SongComment {
  id        String   @id @default(cuid())
  songId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SongLeaderboard {
  id        String @id @default(cuid())
  songId    String
  userId    String
  score     Int
  maxCombo  Int
  accuracy  Float?
  speedMod  Float  @default(1.0)
  modifiers Json?

  createdAt DateTime @default(now())

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([songId, userId], name: "songId_userId")
  @@index([songId, score(sort: Desc)])
}

model SongPlay {
  id           String   @id @default(cuid())
  songId       String
  userId       String
  count        Int      @default(1)
  lastPlayedAt DateTime @default(now())

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([songId, userId])
}

model SynapseStormPlayer {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  highScore      Int      @default(0)
  puzzlesSolved  Int      @default(0)
  maxCombo       Int      @default(0)
  peakDifficulty Float    @default(1)
  totalTime      Float    @default(0)
  updatedAt      DateTime @default(now()) @updatedAt

  @@index([highScore(sort: Desc)])
  @@map("synapse_storm_player")
}

// ─── Synapse Storm Multiplayer ───

enum SSLobbyStatus {
  WAITING
  IN_MATCH
  CLOSED
}

enum SSMatchStatus {
  RUNNING
  FINISHED
}

model SSLobby {
  id         String        @id @default(cuid())
  code       String        @unique
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  status     SSLobbyStatus @default(WAITING)
  hostUserId String

  members SSLobbyMember[]
  matches SSMatch[]

  @@map("ss_lobby")
}

model SSLobbyMember {
  id          String   @id @default(cuid())
  lobbyId     String
  userId      String
  displayName String
  joinedAt    DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  isReady     Boolean  @default(false)
  isHost      Boolean  @default(false)

  lobby SSLobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, userId])
  @@index([lobbyId])
  @@map("ss_lobby_member")
}

model SSMatch {
  id        String        @id @default(cuid())
  lobbyId   String
  seed      Int
  startAt   DateTime
  endAt     DateTime?
  status    SSMatchStatus @default(RUNNING)
  createdAt DateTime      @default(now())

  lobby   SSLobby         @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  players SSPlayerMatch[]

  @@index([lobbyId])
  @@map("ss_match")
}

model SSPlayerMatch {
  id            String    @id @default(cuid())
  matchId       String
  lobbyId       String
  userId        String
  displayName   String
  score         Int       @default(0)
  maxCombo      Int       @default(0)
  puzzlesSolved Int       @default(0)
  puzzlesMissed Int       @default(0)
  finishedAt    DateTime?
  lastUpdateAt  DateTime  @default(now())

  match SSMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@index([matchId])
  @@index([lobbyId])
  @@map("ss_player_match")
}

// --- RMHbox Models ---

model RMHboxProfile {
  id               String              @id @default(cuid())
  userId           String              @unique
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalGamesPlayed Int                 @default(0)
  totalWins        Int                 @default(0)
  totalScore       Int                 @default(0)
  totalPlayTimeMs  Int                 @default(0)
  minigameStats    Json                @default("{}")
  currentWinStreak Int                 @default(0)
  bestWinStreak    Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  matches          RMHboxMatchPlayer[]

  @@index([totalWins(sort: Desc)])
  @@index([totalScore(sort: Desc)])
  @@map("rmhbox_profile")
}

model RMHboxMatch {
  id           String              @id @default(cuid())
  minigameId   String
  lobbyId      String
  startedAt    DateTime            @default(now())
  endedAt      DateTime?
  durationMs   Int?
  winnerUserId String?
  playerCount  Int
  gameLog      Json?
  results      Json
  players      RMHboxMatchPlayer[]

  @@index([minigameId])
  @@index([startedAt(sort: Desc)])
  @@index([lobbyId])
  @@map("rmhbox_match")
}

model RMHboxMatchPlayer {
  id        String        @id @default(cuid())
  matchId   String
  match     RMHboxMatch   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  profileId String
  profile   RMHboxProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  userId    String
  userName  String
  rank      Int
  score     Int
  wasWinner Boolean       @default(false)
  stats     Json          @default("{}")
  createdAt DateTime      @default(now())

  @@unique([matchId, userId])
  @@index([profileId])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("rmhbox_match_player")
}

// ─── RmhTube Models ─────────────────────────────────────────

model RmhTubeRoom {
  id               String    @id // 6-char room code
  name             String?
  hostId           String
  isPublic         Boolean   @default(true)
  password         String?
  maxMembers       Int       @default(20)
  allowMemberQueue Boolean   @default(true)
  allowMemberSkip  Boolean   @default(true)
  autoPlay         Boolean   @default(true)
  scheduledFor     DateTime?
  description      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  closedAt         DateTime?

  host     User                 @relation("RmhTubeHostedRooms", fields: [hostId], references: [id])
  members  RmhTubeRoomMember[]
  messages RmhTubeChatMessage[]
  queue    RmhTubeQueueItem[]

  @@index([isPublic, closedAt])
  @@map("rmhtube_room")
}

model RmhTubeRoomMember {
  id       String    @id @default(cuid())
  roomId   String
  userId   String
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  room RmhTubeRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
  @@map("rmhtube_room_member")
}

model RmhTubeChatMessage {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  userName  String
  content   String
  replyToId String?
  createdAt DateTime @default(now())

  room    RmhTubeRoom          @relation(fields: [roomId], references: [id], onDelete: Cascade)
