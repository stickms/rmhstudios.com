  createdAt DateTime @default(now())

  build UserBuild @relation(fields: [buildId], references: [id], onDelete: Cascade)
  user  User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([buildId, userId])
  @@unique([buildId, ipHash])
  @@map("build_view")
}

// ─── Dream Rift ───────────────────────────────────────────────────

model DreamRiftPlayer {
  id               String   @id @default(uuid())
  username         String   @unique
  highScoreEasy    Int      @default(0)
  highScoreNormal  Int      @default(0)
  highScoreHard    Int      @default(0)
  highScoreLunatic Int      @default(0)
  bestStage        Int      @default(1)
  character        String   @default("rei")
  gamesPlayed      Int      @default(1)
  totalGraze       Int      @default(0)
  spellsCaptured   Int      @default(0)
  updatedAt        DateTime @default(now()) @updatedAt

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([highScoreNormal(sort: Desc)], map: "idx_dream_rift_high_score")
  @@index([bestStage(sort: Desc)], map: "idx_dream_rift_best_stage")
}

// Tracks which Discord channel was last used for an activity per guild.
// Used by the daily recap script to know where to post recaps.
model DiscordActivityChannel {
  id             String    @id @default(cuid())
  guildId        String
  channelId      String
  activity       String    // e.g. "lights-out"
  updatedAt      DateTime  @default(now()) @updatedAt
  // Scheduled recap: set when the first player starts the daily puzzle
  recapDateKey   String?   // YYYY-MM-DD of the puzzle day to recap
  recapDueAt     DateTime? // when to send the recap (24h after first activity)

  @@unique([guildId, activity])
  @@index([recapDueAt], map: "idx_discord_activity_recap_due")
  @@map("discord_activity_channel")
}

// Tracks per-user, per-guild daily puzzle participation.
// A user completing in one guild propagates to all guilds they opened the activity in.
model DiscordDailyParticipant {
  id           String   @id @default(cuid())
  discordId    String   // Discord user ID
  guildId      String
  dateKey      String   // YYYY-MM-DD
  username     String
  status       String   @default("playing") // "playing" | "completed"
  moves        Int?
  ratingEmoji  String?
  ratingLabel  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@unique([discordId, guildId, dateKey])
  @@index([guildId, dateKey], map: "idx_discord_daily_participant_guild_date")
  @@index([discordId, dateKey], map: "idx_discord_daily_participant_user_date")
  @@map("discord_daily_participant")
}

// Tracks per-user daily puzzle progress across guilds/devices (prevents move resets)
model DiscordDailyProgress {
  id          String   @id @default(cuid())
  discordId   String
  dateKey     String   // YYYY-MM-DD
  gridJson    String   // JSON-encoded grid state
  moves       Int      @default(0)
  completed   Boolean  @default(false)
  ratingLabel String?
  ratingEmoji String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@unique([discordId, dateKey])
  @@map("discord_daily_progress")
}

// ═══════════════════════════════════════════════════════════════════════════════
// DOCTRINE ENGINE (RMH Strategies)
// ═══════════════════════════════════════════════════════════════════════════════

enum DoctrinePuzzleMode {
  ALIBI
  SPECTRUM
  OUTCAST
  CHAINLINK
  IMPOSTOR
  SAHUR_SPECIAL
}

enum DoctrineSafehouseType {
  DEV_LOG
  BUILD
  POSTMORTEM
  DECISION
  RAW_FOOTAGE
  FINANCIAL
  VOTE
}

enum DoctrineDisclosureStatus {
  CLASSIFIED
  TEASED
  DISCLOSED
  ARCHIVED
}

enum DoctrineIncidentSeverity {
  COSMETIC
  DEGRADED
  CRITICAL
  CATASTROPHIC
}

enum DoctrineIncidentStatus {
  ACTIVE
  MITIGATED
  RESOLVED
  LEGENDARY
}

enum DoctrineReactionType {
  FIRE
  BASED
  MID
  CRINGE
  TRASH
  TUNG
}

// ─── REPUTATION ─────────────────────────────────────────────────────────────

model DoctrineReputation {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalXp       Int      @default(0)
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  lastActiveAt  DateTime @default(now())
  coalitionScore Float   @default(1.0)
  sahurCount    Int      @default(0)
  ledger        DoctrineReputationLedger[]

  @@index([totalXp(sort: Desc)])
  @@map("doctrine_reputation")
}

model DoctrineReputationLedger {
  id           String             @id @default(cuid())
  reputationId String
  reputation   DoctrineReputation @relation(fields: [reputationId], references: [id], onDelete: Cascade)
  action       String
  xpDelta      Int
  reason       String
  metadata     Json?
  createdAt    DateTime           @default(now())

  @@index([reputationId, createdAt(sort: Desc)])
  @@map("doctrine_reputation_ledger")
}

// ─── PUZZLES ────────────────────────────────────────────────────────────────

model DoctrinePuzzle {
  id          String                     @id @default(cuid())
  mode        DoctrinePuzzleMode
  date        DateTime                   @db.Date
  seed        Int
  data        Json
  difficulty  Int                        @db.SmallInt
  resetsAt    DateTime
  isSahur     Boolean                    @default(false)
  submissions DoctrinePuzzleSubmission[]
  createdAt   DateTime                   @default(now())

  @@unique([mode, date])
  @@index([date(sort: Desc)])
  @@index([mode, date])
  @@map("doctrine_puzzle")
}

model DoctrinePuzzleSubmission {
  id        String         @id @default(cuid())
  puzzleId  String
  puzzle    DoctrinePuzzle @relation(fields: [puzzleId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  answer    Json
  timeMs    Int
  attempts  Int
  correct   Boolean
  score     Int
  createdAt DateTime       @default(now())

  @@unique([puzzleId, userId])
  @@index([puzzleId, score(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("doctrine_puzzle_submission")
}

model DoctrinePuzzleReplay {
  id         String             @id @default(cuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode       DoctrinePuzzleMode
  seed       Int
  data       Json
  difficulty Int                @db.SmallInt
  answer     Json?
  timeMs     Int?
  attempts   Int?
  correct    Boolean?
  score      Int?
  createdAt  DateTime           @default(now())

  @@index([userId, mode, createdAt(sort: Desc)])
  @@map("doctrine_puzzle_replay")
}

// ─── SAFEHOUSE ──────────────────────────────────────────────────────────────

model DoctrineSafehouseContent {
  id          String                @id @default(cuid())
  type        DoctrineSafehouseType
  title       String
  body        String
  minTier     String                @default("INSIDER") // PUBLIC | INSIDER | OPERATOR
  authorId    String
  mediaUrls   String[]
  reactions   DoctrineReaction[]
  accessLogs  DoctrineAccessLog[]
  publishedAt DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([minTier, publishedAt(sort: Desc)])
  @@map("doctrine_safehouse_content")
}

model DoctrineAccessLog {
  id        String                   @id @default(cuid())
  userId    String
  user      User                     @relation(fields: [userId], references: [id])
  contentId String
  content   DoctrineSafehouseContent @relation(fields: [contentId], references: [id])
  viewedAt  DateTime                 @default(now())

  @@unique([userId, contentId])
  @@index([contentId])
  @@map("doctrine_access_log")
}

// ─── DISCLOSURES ────────────────────────────────────────────────────────────

model DoctrineDisclosure {
  id            String                    @id @default(cuid())
  codename      String
  publicTitle   String
  content       String
  narrative     String
  minTierTeaser String                    @default("OPERATOR")
  status        DoctrineDisclosureStatus  @default(CLASSIFIED)
  scheduledAt   DateTime?
  teasedAt      DateTime?
  disclosedAt   DateTime?
  mediaUrls     String[]
  reactions     DoctrineReaction[]
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  @@index([status, scheduledAt])
  @@map("doctrine_disclosure")
}

// ─── RECRUITMENT ────────────────────────────────────────────────────────────

model DoctrineRecruitmentCode {
  id              String   @id @default(cuid())
  code            String   @unique
  recruiterId     String
  recruiter       User     @relation(fields: [recruiterId], references: [id])
  personalMessage String
  targetSkills    String[]
  uses            Int      @default(0)
  maxUses         Int      @default(5)
  expiresAt       DateTime
  convertedIds    String[]
  createdAt       DateTime @default(now())

  @@index([code])
  @@index([recruiterId])
  @@map("doctrine_recruitment_code")
}

// ─── INCIDENTS ──────────────────────────────────────────────────────────────

model DoctrineIncident {
  id              String                   @id @default(cuid())
  codename        String
  severity        DoctrineIncidentSeverity
  title           String
  narrative       String
  status          DoctrineIncidentStatus   @default(ACTIVE)
  firstReporterId String?
  postmortemId    String?
  timeline        DoctrineIncidentEvent[]
  reports         DoctrineIncidentReport[]
  reactions       DoctrineReaction[]
  createdAt       DateTime                 @default(now())
  resolvedAt      DateTime?

  @@index([status, createdAt(sort: Desc)])
  @@map("doctrine_incident")
}

model DoctrineIncidentEvent {
  id         String           @id @default(cuid())
  incidentId String
  incident   DoctrineIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  type       String
  message    String
  createdAt  DateTime         @default(now())

  @@index([incidentId, createdAt])
  @@map("doctrine_incident_event")
}

model DoctrineIncidentReport {
  id         String           @id @default(cuid())
  incidentId String
  incident   DoctrineIncident @relation(fields: [incidentId], references: [id])
  userId     String
  user       User             @relation(fields: [userId], references: [id])
  message    String
  createdAt  DateTime         @default(now())

  @@index([incidentId])
  @@map("doctrine_incident_report")
}

// ─── REACTIONS (polymorphic across doctrine content) ────────────────────────

model DoctrineReaction {
  id           String                    @id @default(cuid())
  userId       String
  user         User                      @relation(fields: [userId], references: [id])
  reaction     DoctrineReactionType
  safehouseId  String?
  safehouse    DoctrineSafehouseContent?  @relation(fields: [safehouseId], references: [id])
  disclosureId String?
  disclosure   DoctrineDisclosure?        @relation(fields: [disclosureId], references: [id])
  incidentId   String?
  incident     DoctrineIncident?          @relation(fields: [incidentId], references: [id])
  createdAt    DateTime                   @default(now())

  @@unique([userId, safehouseId])
  @@unique([userId, disclosureId])
  @@unique([userId, incidentId])
  @@map("doctrine_reaction")
}

// ─── SAHUR MODE ─────────────────────────────────────────────────────────────

model DoctrineSahurSession {
  id               String                       @id @default(cuid())
  dateKey          String
  timezone         String
  activatedAt      DateTime                     @default(now())
  deactivatedAt    DateTime?
  participantCount Int                          @default(0)
  participants     DoctrineSahurParticipation[]

  @@unique([dateKey, timezone])
  @@index([dateKey])
  @@map("doctrine_sahur_session")
}

model DoctrineSahurParticipation {
  id              String               @id @default(cuid())
  sessionId       String
  session         DoctrineSahurSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId          String
  user            User                 @relation(fields: [userId], references: [id])
  joinedAt        DateTime             @default(now())
  puzzlesCompleted Int                 @default(0)
  xpEarned        Int                  @default(0)

  @@unique([sessionId, userId])
  @@map("doctrine_sahur_participation")
}

model DiscordChatSession {
  discordUserId   String   @id
  username        String
  history         Json
  lastMessageId   String?
  updatedAt       DateTime @updatedAt

  @@map("discord_chat_session")
}

model VibePage {
  id                  String   @id @default(cuid())
  slug                String   @unique // short URL-safe identifier, e.g. "neon-city-3k"
  prompt              String            // original user prompt
  title               String?           // model-generated page title (tab + OG)
  description         String?           // model-generated description (OG/social)
  html                String            // full generated HTML — always mirrors the latest version
  thumbnailUrl        String?           // "/api/vibe/thumb/<slug>?v=<ts>" once the screenshot is captured
  thumbnailStale      Boolean  @default(true) // true → the vibe-worker (re)renders the screenshot
  conversationHistory Json              // array of { role, content } turns for "customize" follow-ups
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  versions VibePageVersion[]

  @@index([slug])
  @@map("vibe_page")
}

// One immutable snapshot per generation step (the initial build and every
// "customize" follow-up). Lets people browse the page's history — each version is
// dated/timestamped — and branch a new customization off any earlier variant.
model VibePageVersion {
  id                  String   @id @default(cuid())
  pageId              String
  page                VibePage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  prompt              String            // the prompt that produced this version
  title               String?           // page title at this version
  description         String?           // description at this version
  html                String            // full generated HTML for this version
  conversationHistory Json              // cumulative { role, content } history up to & including this version
  createdAt           DateTime @default(now())

  @@index([pageId, createdAt])
  @@map("vibe_page_version")
}

// ─── LEDGER (Co-Scientist reproducibility substrate) ─────────────────────────

model LedgerArtifact {
  id          String   @id            // "sha256:<hex64>"
  contentType String                  // "fastq" | "bam" | "count_matrix" | "umap_png" | ...
  sizeBytes   BigInt                  // raw byte count
  storagePath String                  // relative path inside artifact root: "<hex[:2]>/<hex64>"
  createdAt   DateTime @default(now())

  stepOutputs LedgerPlanStep[]  @relation("StepOutput")
  stepInputs  LedgerStepInput[]

  @@map("ledger_artifact")
}

model LedgerPlanRun {
  id          String    @id @default(cuid())
  bundleId    String    @unique     // "run-YYYYMMDD-HHMMSS-xxxxxx"
  description String?
  status      String    @default("pending")  // pending | running | completed | failed
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  steps LedgerPlanStep[]

  @@map("ledger_plan_run")
}

model LedgerPlanStep {
  id               String    @id @default(cuid())
  runId            String
  stepIndex        Int
  tool             String    // "fastqc" | "star" | "deseq2" | ...
  toolVersion      String    // "0.11.9" | "2.7.11b" | "1.44.0"
  imageDigest      String?   // "sha256:<container digest>"
  params           Json      // {"--runThreadN": 8, ...}
  status           String    @default("pending")  // pending | running | completed | failed | cached
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  outputArtifactId String?

  run    LedgerPlanRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  output LedgerArtifact? @relation("StepOutput", fields: [outputArtifactId], references: [id])
  inputs LedgerStepInput[]

  @@index([runId, stepIndex])
  @@map("ledger_plan_step")
}

model LedgerStepInput {
  stepId     String
  artifactId String
  role       String  // semantic label: "fastq" | "genome_index" | "count_matrix"

  step     LedgerPlanStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  artifact LedgerArtifact @relation(fields: [artifactId], references: [id])

  @@id([stepId, artifactId])
  @@map("ledger_step_input")
}

// ─── rmhladder ──────────────────────────────────────────────────────────────

enum LadderPlatform {
  greenhouse
  lever
  ashby
  smartrecruiters
  manual
  generic
}

enum LadderSourceStatus {
  active
  unconfigured
  blocked
  error
  disabled
}

enum LadderJobStatus {
  active
  expired
  unknown
}

enum LadderRemoteStatus {
  onsite
  hybrid
  remote_us
}

enum LadderEmploymentType {
  internship
  full_time
}

enum LadderProgramType {
  internship
  summer_analyst
  summer_associate
  analyst_program
  rotational_program
  new_grad
  leadership_development
  entry_level
  mba
  other
}

enum LadderEarlyCareer {
  yes
  probable
  no
  unclear
}

enum LadderVerificationStatus {
  verified_active
  verified_probable
  unverified
  expired
  broken_link
  duplicate
  non_us_role
  blocked_or_inaccessible
  needs_manual_review
}

enum LadderReviewReason {
  broken_link
  blocked
  js_required
  possible_duplicate
  ambiguous_early_career
  ambiguous_us_location
  low_confidence
  aggregator_unconfirmed
  mass_expiry_suspected
}

enum LadderReviewStatus {
  open
  resolved
  dismissed
}

enum LadderRunTrigger {
  cron
  manual
}

model LadderCompany {
  id               String   @id @default(cuid())
  name             String
  normalizedName   String   @unique
  industry         String
  firmType         String
  priorityLevel    Int      @default(3) // 1 high .. 5 low
  careerUrl        String?
  usEarlyCareerUrl String?
  campusUrl        String?
  notes            String?
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now())

  sources           LadderSource[]
  jobs              LadderJob[]
  watchlistEntries  LadderWatchlistEntry[]

  @@map("ladder_company")
}

model LadderSource {
  id            String             @id @default(cuid())
  companyId     String
  company       LadderCompany      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  platform      LadderPlatform
  slug          String?
  url           String?
  status        LadderSourceStatus @default(unconfigured)
  lastSuccessAt DateTime?
  createdAt     DateTime           @default(now())

  errors      LadderSourceError[]
  reviewTasks LadderReviewTask[]

  @@unique([companyId, platform, slug])
  @@map("ladder_source")
}

model LadderJob {
  id                       String                @id @default(cuid())
  companyId                String
  company                  LadderCompany         @relation(fields: [companyId], references: [id])
  title                    String
  normalizedTitle          String
  roleCategory             String?
  programType              LadderProgramType     @default(other)
  industry                 String?
  locationRaw              String?
  city                     String?
  state                    String?
  country                  String                @default("US")
  remoteStatus             LadderRemoteStatus    @default(onsite)
  employmentType           LadderEmploymentType  @default(internship)
  postingDate              DateTime?
  applicationDeadline      DateTime?
  startSeason              String?
  graduationYearTarget     Int?
  schoolYearTarget         String?
  sourcePlatform           LadderPlatform
  sourceUrl                String
  originalPostingUrl       String
  canonicalApplyUrl        String?
  externalRequisitionId    String?
  externalId               String?
  descriptionSummary       String?
  fullDescription          String?
  dedupeHash               String                @unique
  alternateUrls            String[]              @default([])
  matchingKeywords         String[]              @default([])
  status                   LadderJobStatus       @default(unknown)
  failedCheckCount         Int                   @default(0)
  earlyCareerScore         Int                   @default(0)
  earlyCareerClassification LadderEarlyCareer    @default(unclear)
  usLocationConfidence     Int                   @default(0)
  relevanceScoreBase       Int                   @default(0)
  urgencyFlag              Boolean               @default(false)
  discoveredAt             DateTime              @default(now())
  lastCheckedAt            DateTime?
  lastVerifiedAt           DateTime?

  verifications LadderVerification[]
  reviewTasks   LadderReviewTask[]
  actions       LadderJobAction[]
  applications  LadderApplication[]
  alerts        LadderAlert[]

  @@index([status, earlyCareerClassification])
  @@index([companyId, status])
  @@map("ladder_job")
}

model LadderVerification {
  id         String                   @id @default(cuid())
  jobId      String
  job        LadderJob                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status     LadderVerificationStatus
  confidence Int // 0-100
  evidence   String
  checkedAt  DateTime                 @default(now())

  @@index([jobId, checkedAt])
  @@map("ladder_verification")
}

model LadderScrapeRun {
  id             String           @id @default(cuid())
  trigger        LadderRunTrigger
  startedAt      DateTime         @default(now())
  finishedAt     DateTime?
  discoveredCount Int             @default(0)
  newCount       Int              @default(0)
  verifiedCount  Int              @default(0)
  expiredCount   Int              @default(0)
  errorCount     Int              @default(0)
  stats          Json?

  errors LadderSourceError[]

  @@map("ladder_scrape_run")
}

model LadderSourceError {
  id        String          @id @default(cuid())
  runId     String
  run       LadderScrapeRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  sourceId  String
  source    LadderSource    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  errorClass String
  message   String
  httpStatus Int?
  createdAt DateTime        @default(now())

  @@map("ladder_source_error")
}

model LadderReviewTask {
  id         String             @id @default(cuid())
  jobId      String?
  job        LadderJob?         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  sourceId   String?
  source     LadderSource?      @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  reason     LadderReviewReason
  status     LadderReviewStatus @default(open)
  resolution String?
  resolvedById String?
  createdAt  DateTime           @default(now())
  resolvedAt DateTime?

  @@map("ladder_review_task")
}

model LadderRelevanceRule {
  id        String  @id @default(cuid())
  key       String  @unique
  label     String
  weight    Int
  enabled   Boolean @default(true)

  @@map("ladder_relevance_rule")
}

// ─── RMH Ladder Per-User Models ──────────────────────────────────────

enum LadderKeywordType {
  boost
  block
}

enum LadderJobActionType {
  saved
  applied
  ignored
}

enum LadderApplicationStatus {
  not_applied
  planning
  applied
  networking
  interviewing
  final_round
  rejected
  offer
  withdrawn
}

enum LadderAlertChannel {
  in_app
  email
  discord
}

enum LadderAlertType {
  immediate
  daily_digest
  weekly_digest
  deadline
  changed
  expired
  review_needed
}

enum LadderDigestFrequency {
  immediate
  daily
  weekly
}

model LadderUserPrefs {
  id                    String                  @id @default(cuid())
  userId                String                  @unique
  user                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
