// ─── Prediction markets ────────────────────────────────────────────

enum PredictionStatus {
  PENDING // submitted by a user, awaiting admin approval
  OPEN // approved, trading is live
  RESOLVED_YES
  RESOLVED_NO
  DENIED // rejected by an admin
}

/// A binary (YES/NO) prediction market priced by an LMSR market maker. The live
/// YES price is the implied probability and moves as users trade. Shares pay 1
/// coin each on the winning side at resolution. `creatorId` is null for markets
/// seeded by the DeepSeek worker.
model Prediction {
  id            String           @id @default(cuid())
  title         String           @db.VarChar(160)
  description   String?          @db.VarChar(1000)
  creatorId     String?
  status        PredictionStatus @default(PENDING)
  isAiGenerated Boolean          @default(false)

  // LMSR state (floats). Shares pay 1 coin each on the winning side.
  b      Float @default(120) // liquidity parameter
  qYes   Float @default(0) // YES shares outstanding
  qNo    Float @default(0) // NO shares outstanding
  volume Int   @default(0) // total coins traded (display only)

  closesAt   DateTime? // trading deadline
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  creator   User?                @relation("PredictionCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  positions PredictionPosition[]

  @@index([status, createdAt(sort: Desc)])
  @@map("prediction")
}

/// A user's aggregate holdings in a single market. Updated per trade; settled at
/// resolution (winning shares credited back as coins).
model PredictionPosition {
  id           String  @id @default(cuid())
  predictionId String
  userId       String
  yesShares    Float   @default(0)
  noShares     Float   @default(0)
  spent        Int     @default(0) // net coins spent (cost basis)
  settled      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prediction Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  user       User       @relation("PredictionPositions", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([predictionId, userId])
  @@index([userId])
  @@map("prediction_position")
}

