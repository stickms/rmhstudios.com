generator client {
  provider        = "prisma-client-js"
  // Skip engine binary — the pg adapter uses the JS-based query engine
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
}

// User Model (Better Auth)
model User {
  id            String   @id @default(cuid())
  name          String?
  username        String?   @unique // Added for username login
  handle          String?   @unique // Unique user handle for @mentions and URLs
  handleChangedAt DateTime? // Last time the handle was changed (2-week cooldown)
  email           String?   @unique
  emailVerified   Boolean?
  password        String?   // Added for password login
  image           String?
  isAdmin         Boolean   @default(false)
  isVerified      Boolean   @default(false)
  // ─── RMHark AI bot users (generated + driven by the bot-worker) ──
  isBot           Boolean   @default(false) // synthetic account created by the bot-worker
  botPersona      String?   @db.Text         // private prompt seed describing the bot's posting "theme"
  botLastPostAt   DateTime?                   // last time the worker posted as this bot (pacing)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sessions Session[]
  accounts Account[]

  // Game Relations (Progression linked to User)
  altairProfile       AltairPlayer?
  altairMetaProgress  AltairMetaProgress?
  altairCoopProfile   AltairCoopProfile?
  altairMatchPlayers  AltairMatchPlayer[]
  laundryProfile      LaundryPlayer?
  sliceItProfile      Player?
  vegaProfile         VegaPlayer?
  signalForgeProfile  SignalForgePlayer?
  templeOfJoyProfile  TempleOfJoySave?
  neonDriftwayProfile NeonDriftwayPlayer?
  synapseStormProfile SynapseStormPlayer?
  rmhboxProfile       RMHboxProfile?
  rmhtypeProfiles     RmhTypeProfile[]
  rmhstudyProfile     RmhStudyProfile?
  voidBreakerProfile  VoidBreakerPlayer?
  dailyPuzzleScores   DailyPuzzleScore[]
  versecraftSave      VersecraftSave?
  versecraftProgress  VersecraftProgress?
  forestExplorerSave  ForestExplorerSave?
  dreamRiftProfile    DreamRiftPlayer?

  // Slice-It Library Relations
  uploadedSongs Song[]            @relation("SongUploader")
  songLikes     SongLike[]
  songRatings   SongRating[]
  songComments  SongComment[]
  songScores    SongLeaderboard[]
  songPlays     SongPlay[]

  // RmhTube Relations
  rmhtubeHostedRooms RmhTubeRoom[]       @relation("RmhTubeHostedRooms")
  rmhtubeRoomMembers RmhTubeRoomMember[]
  rmhtubeQueueItems  RmhTubeQueueItem[]
  rmhtubePlaylists   RmhTubePlaylist[]
  rmhtubeStats       RmhTubeUserStats?

  // ─── RMHMusic ──────────────────────────────────────────────────
  rmhMusicHostedRooms  RmhMusicRoom[]        @relation("RmhMusicHostedRooms")
  rmhMusicRoomMembers  RmhMusicRoomMember[]  @relation("RmhMusicRoomMembers")
  rmhMusicQueueItems   RmhMusicQueueItem[]   @relation("RmhMusicQueueItems")
  rmhMusicChatMessages RmhMusicChatMessage[] @relation("RmhMusicChatMessages")

  // Site Feedback
  feedbacks Feedback[]

  // RMHark (Feed) Relations
  rmharks              RMHark[]
  rmharkLikes          RMHarkLike[]
  rmharkComments       RMHarkComment[]
  rmharkReposts        RMHarkRepost[]
  rmharkViews          RMHarkView[]
  rmharkCommentLikes   RMHarkCommentLike[]
  rmharkCommentReposts RMHarkCommentRepost[]
  rmharkCommentViews   RMHarkCommentView[]
  rmharkPollVotes      RMHarkPollVote[]

  // Profile & Social
  profile   UserProfile?
  followers Follow[]     @relation("UserFollowing")
  following Follow[]     @relation("UserFollowers")

  // Direct Messages
  conversationsAsOne Conversation[]  @relation("ConversationParticipantOne")
  conversationsAsTwo Conversation[]  @relation("ConversationParticipantTwo")
  directMessages     DirectMessage[]

  // rmhcode & User Builds
  rmhCodeTokens RmhCodeToken[]
  userBuilds    UserBuild[]
  buildLikes    BuildLike[]
  buildComments BuildComment[]
  buildViews    BuildView[]

  // ─── Doctrine Engine (RMH Strategies) ─────────────────────────
  doctrineTier          String    @default("PUBLIC") // PUBLIC | INSIDER | OPERATOR
  doctrineTierChangedAt DateTime?
  doctrineTimezone      String    @default("America/New_York")
  doctrineRecruitedById String?
  doctrineRecruitedBy   User?                         @relation("DoctrineRecruitment", fields: [doctrineRecruitedById], references: [id])
  doctrineRecruits      User[]                        @relation("DoctrineRecruitment")
  doctrineReputation          DoctrineReputation?
  doctrinePuzzleSubmissions   DoctrinePuzzleSubmission[]
  doctrinePuzzleReplays       DoctrinePuzzleReplay[]
  doctrineSafehouseAccessLogs DoctrineAccessLog[]
  doctrineIncidentReports     DoctrineIncidentReport[]
  doctrineReactions           DoctrineReaction[]
  doctrineRecruitmentCodes    DoctrineRecruitmentCode[]
  doctrineSahurParticipations DoctrineSahurParticipation[]

  // RMH Ladder Relations
  ladderPrefs        LadderUserPrefs?
  ladderKeywords     LadderKeyword[]
  ladderWatchlist    LadderWatchlistEntry[]
  ladderJobActions   LadderJobAction[]
  ladderApplications LadderApplication[]
  ladderAlerts       LadderAlert[]

  @@index([isBot])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  expiresAt             DateTime? // Re-added for Better Auth compatibility
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// --- Blog Models ---

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  date        String
  description String
  image       String?
  tags        String[]
  content     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date(sort: Desc)])
  @@map("blog_post")
}

// --- Game Models ---

model AltairPlayer {
  id                String   @id @default(uuid())
  username          String   @unique
  bestTime          Float    @default(0)
  totalKills        Int      @default(0)
  totalXP           Int      @default(0)
  totalGold         Int      @default(0)
  totalTimeSurvived Float    @default(0)
  gamesPlayed       Int      @default(1)
  updatedAt         DateTime @default(now()) @updatedAt

  // Link to Auth User
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bestTime(sort: Desc)], map: "idx_altair_best_time")
  @@index([totalKills(sort: Desc)], map: "idx_altair_kills")
  @@index([totalXP(sort: Desc)], map: "idx_altair_xp")
  @@index([totalGold(sort: Desc)], map: "idx_altair_gold")
  @@index([totalTimeSurvived(sort: Desc)], map: "idx_altair_survival")
}

model LaundryPlayer {
  id          String   @id @default(uuid())
  username    String   @unique
  highScore   Int      @default(0)
  gamesPlayed Int      @default(1)
  updatedAt   DateTime @default(now()) @updatedAt

  // Link to Auth User
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([highScore(sort: Desc)], map: "idx_laundry_high_score")
}

// Daily Puzzle Score — generic leaderboard for all daily puzzles including lights-out
model DailyPuzzleScore {
  id        String   @id @default(cuid())
  userId    String
  gameMode  String   // lights-out | alibi | spectrum | outcast | chainlink | impostor
  dateKey   String   // YYYY-MM-DD
  score     Int      @default(0)   // points (higher = better) for most games
  moves     Int?                    // lights-out: move count (lower = better)
  hintUsed  Boolean? @default(false) // lights-out: whether hints were used
  dnf         Boolean? @default(false) // lights-out: did not finish
  resultJson  Json?                    // game-specific result data
  timeSeconds Int?                     // time taken (for timed games)
  createdAt   DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameMode, dateKey])
  @@index([gameMode, dateKey, score(sort: Desc)])
  @@index([gameMode, dateKey, moves(sort: Asc)])
  @@map("daily_puzzle_score")
}

// Slice It Player Model
model Player {
  id          String   @id @default(cuid())
  username    String   @unique
  totalScore  Int      @default(0)
  gamesPlayed Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Link to Auth User
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VegaPlayer {
  id           String   @id @default(uuid())
  username     String   @unique
  highestLoop  Int      @default(1)
  highestLevel Int      @default(1)
  gamesPlayed  Int      @default(0)
  updatedAt    DateTime @default(now()) @updatedAt

  // Link to Auth User
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([highestLoop(sort: Desc)], map: "idx_vega_loop")
  @@index([highestLevel(sort: Desc)], map: "idx_vega_level")
}

model SignalForgePlayer {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username      String   @unique
  highScore     Int      @default(0)
  floorReached  Int      @default(1)
  gamesPlayed   Int      @default(1)
  savedRunState Json?
  updatedAt     DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Link to Auth User
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([highScore(sort: Desc)], map: "idx_signal_forge_high_score")
  @@index([floorReached(sort: Desc)], map: "idx_signal_forge_floor")
}

model TempleOfJoySave {
  id        String   @id @default(cuid())
  userId    String   @unique
  saveData  Json
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("temple_of_joy_save")
}

model NeonDriftwayPlayer {
  id           String   @id @default(uuid())
  username     String   @unique
  highScore    Int      @default(0)
  bestDistance Int      @default(0)
  bestTimeMs   Int      @default(0)
  bestLevel    Int      @default(1)
  gamesPlayed  Int      @default(1)
  updatedAt    DateTime @default(now()) @updatedAt

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([highScore(sort: Desc)], map: "idx_neon_driftway_high_score")
}

model VoidBreakerPlayer {
  id          String   @id @default(uuid())
  username    String   @unique
  highScore   Int      @default(0)
  bestWave    Int      @default(0)
  totalKills  Int      @default(0)
  bestTimeMs  Int      @default(0)
  gamesPlayed Int      @default(1)
  updatedAt   DateTime @default(now()) @updatedAt

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([highScore(sort: Desc)], map: "idx_void_breaker_high_score")
}

// --- Slice-It Music Library Models ---

model Song {
  id          String  @id @default(cuid())
  title       String
  artist      String
  album       String?
  description String?
  duration    Float
  bpm         Float?

  audioUrl      String
  coverUrl      String?
  fileSizeBytes Int? // bytes of audio file (for 10 GB total storage cap)

  // Audio Analysis Data (JSON for beatmap generation)
  analysisData Json?

  uploadedBy String
  uploader   User   @relation("SongUploader", fields: [uploadedBy], references: [id])

  isPublic Boolean @default(true)
  plays    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ratings   SongRating[]
  comments  SongComment[]
  scores    SongLeaderboard[]
  likes     SongLike[]
  songPlays SongPlay[]

  @@index([title])
  @@index([artist])
  @@index([uploadedBy])
}

model SongLike {
  id        String   @id @default(cuid())
  songId    String
  userId    String
  createdAt DateTime @default(now())

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([songId, userId])
}

model SongRating {
  id        String   @id @default(cuid())
  songId    String
  userId    String
  rating    Int // 1-5
  createdAt DateTime @default(now())

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([songId, userId])
}

model SongComment {
  id        String   @id @default(cuid())
  songId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SongLeaderboard {
  id        String @id @default(cuid())
  songId    String
  userId    String
  score     Int
  maxCombo  Int
  accuracy  Float?
  speedMod  Float  @default(1.0)
  modifiers Json?

  createdAt DateTime @default(now())

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([songId, userId], name: "songId_userId")
  @@index([songId, score(sort: Desc)])
}

model SongPlay {
  id           String   @id @default(cuid())
  songId       String
  userId       String
  count        Int      @default(1)
  lastPlayedAt DateTime @default(now())

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([songId, userId])
}

model SynapseStormPlayer {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  highScore      Int      @default(0)
  puzzlesSolved  Int      @default(0)
  maxCombo       Int      @default(0)
  peakDifficulty Float    @default(1)
  totalTime      Float    @default(0)
  updatedAt      DateTime @default(now()) @updatedAt

  @@index([highScore(sort: Desc)])
  @@map("synapse_storm_player")
}

// ─── Synapse Storm Multiplayer ───

enum SSLobbyStatus {
  WAITING
  IN_MATCH
  CLOSED
}

enum SSMatchStatus {
  RUNNING
  FINISHED
}

model SSLobby {
  id         String        @id @default(cuid())
  code       String        @unique
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  status     SSLobbyStatus @default(WAITING)
  hostUserId String

  members SSLobbyMember[]
  matches SSMatch[]

  @@map("ss_lobby")
}

model SSLobbyMember {
  id          String   @id @default(cuid())
  lobbyId     String
  userId      String
  displayName String
  joinedAt    DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  isReady     Boolean  @default(false)
  isHost      Boolean  @default(false)

  lobby SSLobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, userId])
  @@index([lobbyId])
  @@map("ss_lobby_member")
}

model SSMatch {
  id        String        @id @default(cuid())
  lobbyId   String
  seed      Int
  startAt   DateTime
  endAt     DateTime?
  status    SSMatchStatus @default(RUNNING)
  createdAt DateTime      @default(now())

  lobby   SSLobby         @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  players SSPlayerMatch[]

  @@index([lobbyId])
  @@map("ss_match")
}

model SSPlayerMatch {
  id            String    @id @default(cuid())
  matchId       String
  lobbyId       String
  userId        String
  displayName   String
  score         Int       @default(0)
  maxCombo      Int       @default(0)
  puzzlesSolved Int       @default(0)
  puzzlesMissed Int       @default(0)
  finishedAt    DateTime?
  lastUpdateAt  DateTime  @default(now())

  match SSMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@index([matchId])
  @@index([lobbyId])
  @@map("ss_player_match")
}

// --- RMHbox Models ---

model RMHboxProfile {
  id               String              @id @default(cuid())
  userId           String              @unique
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalGamesPlayed Int                 @default(0)
  totalWins        Int                 @default(0)
  totalScore       Int                 @default(0)
  totalPlayTimeMs  Int                 @default(0)
  minigameStats    Json                @default("{}")
  currentWinStreak Int                 @default(0)
  bestWinStreak    Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  matches          RMHboxMatchPlayer[]

  @@index([totalWins(sort: Desc)])
  @@index([totalScore(sort: Desc)])
  @@map("rmhbox_profile")
}

model RMHboxMatch {
  id           String              @id @default(cuid())
  minigameId   String
  lobbyId      String
  startedAt    DateTime            @default(now())
  endedAt      DateTime?
  durationMs   Int?
  winnerUserId String?
  playerCount  Int
  gameLog      Json?
  results      Json
  players      RMHboxMatchPlayer[]

  @@index([minigameId])
  @@index([startedAt(sort: Desc)])
  @@index([lobbyId])
  @@map("rmhbox_match")
}

model RMHboxMatchPlayer {
  id        String        @id @default(cuid())
  matchId   String
  match     RMHboxMatch   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  profileId String
  profile   RMHboxProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  userId    String
  userName  String
  rank      Int
  score     Int
  wasWinner Boolean       @default(false)
  stats     Json          @default("{}")
  createdAt DateTime      @default(now())

  @@unique([matchId, userId])
  @@index([profileId])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("rmhbox_match_player")
}

// ─── RmhTube Models ─────────────────────────────────────────

model RmhTubeRoom {
  id               String    @id // 6-char room code
  name             String?
  hostId           String
  isPublic         Boolean   @default(true)
  password         String?
  maxMembers       Int       @default(20)
  allowMemberQueue Boolean   @default(true)
  allowMemberSkip  Boolean   @default(true)
  autoPlay         Boolean   @default(true)
  scheduledFor     DateTime?
  description      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  closedAt         DateTime?

  host     User                 @relation("RmhTubeHostedRooms", fields: [hostId], references: [id])
  members  RmhTubeRoomMember[]
  messages RmhTubeChatMessage[]
  queue    RmhTubeQueueItem[]

  @@index([isPublic, closedAt])
  @@map("rmhtube_room")
}

model RmhTubeRoomMember {
  id       String    @id @default(cuid())
  roomId   String
  userId   String
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  room RmhTubeRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
  @@map("rmhtube_room_member")
}

model RmhTubeChatMessage {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  userName  String
  content   String
  replyToId String?
  createdAt DateTime @default(now())

  room    RmhTubeRoom          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  replyTo RmhTubeChatMessage?  @relation("ChatReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies RmhTubeChatMessage[] @relation("ChatReplies")

  @@index([roomId, createdAt])
  @@map("rmhtube_chat_message")
}

model RmhTubeQueueItem {
  id           String    @id @default(cuid())
  roomId       String
  url          String
  mediaType    String
  title        String
  duration     Int?
  thumbnailUrl String?
  addedById    String
  addedByName  String
  position     Int
  playedAt     DateTime?
  createdAt    DateTime  @default(now())

  room    RmhTubeRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  addedBy User        @relation(fields: [addedById], references: [id])

  @@index([roomId, position])
  @@map("rmhtube_queue_item")
}

model RmhTubePlaylist {
  id        String   @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User                  @relation(fields: [userId], references: [id])
  items RmhTubePlaylistItem[]

  @@index([userId])
  @@map("rmhtube_playlist")
}

model RmhTubePlaylistItem {
  id           String  @id @default(cuid())
  playlistId   String
  url          String
  mediaType    String
  title        String
  duration     Int?
  thumbnailUrl String?
  position     Int

  playlist RmhTubePlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([playlistId, position])
  @@map("rmhtube_playlist_item")
}

model RmhTubeUserStats {
  userId                String   @id
  totalWatchTimeMinutes Int      @default(0)
  videosWatched         Int      @default(0)
  roomsCreated          Int      @default(0)
  roomsJoined           Int      @default(0)
  messagesSent          Int      @default(0)
  reactionsUsed         Int      @default(0)
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("rmhtube_user_stats")
}

// ─── RMH Type Models ───────────────────────────────────────

model RmhTypeProfile {
  id               String               @id @default(cuid())
  userId           String
  difficulty       String               @default("medium")
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalGamesPlayed Int                  @default(0)
  totalWins        Int                  @default(0)
  bestWpm          Float                @default(0)
  bestWpmAccuracy  Float                @default(0)
  avgWpm           Float                @default(0)
  bestAccuracy     Float                @default(0)
  avgAccuracy      Float                @default(0)
  totalCharsTyped  Int                  @default(0)
  totalTimeMs      Int                  @default(0)
  currentStreak    Int                  @default(0)
  bestStreak       Int                  @default(0)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  matches          RmhTypeMatchPlayer[]

  @@unique([userId, difficulty])
  @@index([difficulty, bestWpm(sort: Desc)])
  @@index([totalWins(sort: Desc)])
  @@map("rmhtype_profile")
}

model RmhTypeMatch {
  id            String               @id @default(cuid())
  roomId        String
  difficulty    String
  passageId     String
  passageLength String
  rounds        Int
  startedAt     DateTime             @default(now())
  endedAt       DateTime?
  durationMs    Int?
  winnerUserId  String?
  playerCount   Int
  isSolo        Boolean              @default(false)
  results       Json
  players       RmhTypeMatchPlayer[]

  @@index([startedAt(sort: Desc)])
  @@index([winnerUserId])
  @@map("rmhtype_match")
}

model RmhTypeMatchPlayer {
  id        String         @id @default(cuid())
  matchId   String
  match     RmhTypeMatch   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  profileId String
  profile   RmhTypeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  userId    String
  userName  String
  rank      Int
  wpm       Float
  accuracy  Float
  timeMs    Int
  score     Int
  wasWinner Boolean        @default(false)
  createdAt DateTime       @default(now())

  @@unique([matchId, userId])
  @@index([profileId])
  @@index([userId])
