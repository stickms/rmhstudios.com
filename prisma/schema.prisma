  UNLISTED
  PRIVATE
}

model UserBuild {
  id           String          @id @default(cuid())
  userId       String
  slug         String          @unique
  title        String          @db.VarChar(100)
  description  String          @db.VarChar(500)
  readme       String?         @db.Text
  repoUrl      String?         @db.VarChar(500)
  demoUrl      String?         @db.VarChar(500)
  thumbnailUrl String?         @db.VarChar(500)
  visibility   BuildVisibility @default(PUBLIC)
  featured     Boolean         @default(false)
  isCurated    Boolean         @default(false) // Added for "Official Build" status
  position     Int             @default(0) // Added for manual sorting by admins
  technologies Json            @default("[]")
  likeCount    Int             @default(0)
  commentCount Int             @default(0)
  viewCount    Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  publishedAt  DateTime?

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   BuildCategory? @relation(fields: [categoryId], references: [id])
  categoryId String?
  versions   BuildVersion[]
  tags       BuildTag[]
  likes      BuildLike[]
  comments   BuildComment[]
  views      BuildView[]

  @@index([userId])
  @@index([visibility, publishedAt(sort: Desc)])
  @@index([slug])
  @@map("user_build")
}

model BuildVersion {
