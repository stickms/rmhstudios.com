model RmhMusicRoomMember {
  id       String       @id @default(cuid())
  roomId   String
  room     RmhMusicRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId   String
  user     User         @relation("RmhMusicRoomMembers", fields: [userId], references: [id])
  joinedAt DateTime     @default(now())
  leftAt   DateTime?

  @@unique([roomId, userId])
  @@map("rmh_music_room_member")
}

model RmhMusicQueueItem {
  id          String       @id @default(cuid())
  roomId      String
  room        RmhMusicRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  spotifyUri  String
  title       String       @db.VarChar(256)
  artist      String       @db.VarChar(256)
  albumArt    String       @db.VarChar(500)
  durationMs  Int
  addedById   String
  addedBy     User         @relation("RmhMusicQueueItems", fields: [addedById], references: [id])
  addedByName String       @db.VarChar(50)
  position    Int
  playedAt    DateTime?
  createdAt   DateTime     @default(now())

  @@index([roomId, position])
  @@map("rmh_music_queue_item")
}

model RmhMusicChatMessage {
  id        String       @id @default(cuid())
  roomId    String
  room      RmhMusicRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation("RmhMusicChatMessages", fields: [userId], references: [id])
  userName  String       @db.VarChar(50)
  content   String       @db.VarChar(300)
  createdAt DateTime     @default(now())

  @@index([roomId, createdAt(sort: Desc)])
  @@map("rmh_music_chat_message")
}

/// "Guess the song" puzzle (#33). Players reveal progressive text hints and
/// guess the title; needs no external audio. Answers are matched leniently
/// against `acceptedAnswers`.
model MusicGuessPuzzle {
  id              String   @id @default(cuid())
  authorId        String
  title           String   @db.VarChar(160) // canonical answer (song title)
  artist          String   @db.VarChar(160)
  hints           Json // ordered array of hint strings
  acceptedAnswers Json // lowercased acceptable answers
  plays           Int      @default(0)
  solves          Int      @default(0)
  createdAt       DateTime @default(now())

  author   User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  attempts MusicGuessAttempt[]

  @@index([createdAt(sort: Desc)])
  @@map("music_guess_puzzle")
}

model MusicGuessAttempt {
  id        String   @id @default(cuid())
  puzzleId  String
  userId    String
  solved    Boolean  @default(false)
  hintsUsed Int      @default(0)
  createdAt DateTime @default(now())

  puzzle MusicGuessPuzzle @relation(fields: [puzzleId], references: [id], onDelete: Cascade)
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([puzzleId, userId])
  @@index([userId])
  @@map("music_guess_attempt")
}

/// A developer API key for the subscriber-gated REST API. Only a SHA-256 hash
/// of the key is stored — the plaintext is shown to the user exactly once at
/// creation. `prefix` is a short, non-secret label for the UI.
model DeveloperApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String    @db.VarChar(100)
  prefix     String    @db.VarChar(16)
  hashedKey  String    @unique
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("developer_api_key")
}

/// Records a one-time promotional claim (e.g. the free-month offer) so the
/// server can enforce once-ever redemption regardless of client state.
model PromoClaim {
  id        String   @id @default(cuid())
  userId    String
  promo     String   @db.VarChar(64)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, promo])
  @@map("promo_claim")
}

// ─── DM Privacy ───────────────────────────────────────────────────

enum DmPrivacy {
  EVERYONE
  FOLLOWERS
  NONE
}

// ─── Direct Messages ──────────────────────────────────────────────

model Conversation {
  id               String   @id @default(cuid())
  participantOneId String
  participantTwoId String
  lastMessageAt    DateTime @default(now())
  createdAt        DateTime @default(now())

  participantOne User            @relation("ConversationParticipantOne", fields: [participantOneId], references: [id], onDelete: Cascade)
  participantTwo User            @relation("ConversationParticipantTwo", fields: [participantTwoId], references: [id], onDelete: Cascade)
  messages       DirectMessage[]

  @@unique([participantOneId, participantTwoId])
  @@index([participantOneId, lastMessageAt(sort: Desc)])
  @@index([participantTwoId, lastMessageAt(sort: Desc)])
  @@map("conversation")
}

model DirectMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String   @db.VarChar(2000)
  // Optional rich media — mirrors RMHark posts. A message can be text, media,
  // or both. gifUrl is a single GIF (KLIPY/Tenor/Giphy/direct); imageUrls are
  // up to 4 feed-image URLs owned by the sender.
  gifUrl         String?  @db.Text
  imageUrls      String[] @default([])
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("direct_message")
}

// ─── rmhcode CLI Authentication ─────────────────────────────────────

model RmhCodeToken {
  id         String    @id @default(cuid())
  userId     String
  token      String    @unique
  name       String?   @db.VarChar(100)
  lastUsedAt DateTime?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("rmhcode_token")
}

// ─── User Builds ────────────────────────────────────────────────────

enum BuildVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

model UserBuild {
  id           String          @id @default(cuid())
  userId       String
  slug         String          @unique
  title        String          @db.VarChar(100)
  description  String          @db.VarChar(500)
  readme       String?         @db.Text
  repoUrl      String?         @db.VarChar(500)
  demoUrl      String?         @db.VarChar(500)
  thumbnailUrl String?         @db.VarChar(500)
  visibility   BuildVisibility @default(PUBLIC)
  featured     Boolean         @default(false)
  isCurated    Boolean         @default(false) // Added for "Official Build" status
  position     Int             @default(0) // Added for manual sorting by admins
  technologies Json            @default("[]")
  // Marketplace: coins to unlock the readme/repo/demo (null/0 = free).
  price        Int?
  likeCount    Int             @default(0)
  commentCount Int             @default(0)
  viewCount    Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  publishedAt  DateTime?

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   BuildCategory? @relation(fields: [categoryId], references: [id])
  categoryId String?
  versions   BuildVersion[]
  tags       BuildTag[]
  likes      BuildLike[]
  comments   BuildComment[]
  views      BuildView[]
  unlocks    BuildUnlock[]

  @@index([userId])
  @@index([visibility, publishedAt(sort: Desc)])
  @@index([slug])
  @@map("user_build")
}

/// A paid unlock of a build's gated content (#16). Mirrors PostUnlock.
model BuildUnlock {
  id        String   @id @default(cuid())
  userId    String
  buildId   String
  pricePaid Int
  createdAt DateTime @default(now())

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  build UserBuild @relation(fields: [buildId], references: [id], onDelete: Cascade)

  @@unique([userId, buildId])
  @@index([buildId])
  @@map("build_unlock")
}

/// Per-game ELO rating for ranked play (#5). Updated when a challenge resolves.
model EloRating {
  id        String   @id @default(cuid())
  userId    String
  game      String   @db.VarChar(40)
  rating    Int      @default(1000)
  wins      Int      @default(0)
  losses    Int      @default(0)
  draws     Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, game])
  @@index([game, rating(sort: Desc)])
  @@map("elo_rating")
}

/// An async ranked challenge between two players. The result is trust-reported
/// by either participant; resolving it updates both ELO ratings.
model RankedChallenge {
  id           String    @id @default(cuid())
  game         String    @db.VarChar(40)
  challengerId String
  opponentId   String
  status       String    @db.VarChar(12) @default("pending") // pending|accepted|declined|done
  winnerId     String? // null winner on a done challenge = draw
  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?

  challenger User @relation("ChallengeChallenger", fields: [challengerId], references: [id], onDelete: Cascade)
  opponent   User @relation("ChallengeOpponent", fields: [opponentId], references: [id], onDelete: Cascade)

  @@index([opponentId, status])
  @@index([challengerId, status])
  @@map("ranked_challenge")
}

/// A coin-funded gift membership (#18). Grants a tier for a time window,
/// independent of Stripe billing. getUserTier folds active grants in.
model GiftMembership {
  id        String   @id @default(cuid())
  userId    String // recipient
  gifterId  String? // null = system grant
  tier      String   @db.VarChar(16) // 'starter' | 'pro'
  expiresAt DateTime
  createdAt DateTime @default(now())

  user   User  @relation("GiftRecipient", fields: [userId], references: [id], onDelete: Cascade)
  gifter User? @relation("GiftGifter", fields: [gifterId], references: [id], onDelete: SetNull)

  @@index([userId, expiresAt])
  @@map("gift_membership")
}

/// A group direct-message thread (#15). Distinct from 1-on-1 Conversations.
model GroupChat {
  id            String   @id @default(cuid())
  name          String   @db.VarChar(60)
  ownerId       String
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  owner    User              @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members  GroupChatMember[]
  messages GroupMessage[]

  @@map("group_chat")
}

model GroupChatMember {
  id         String   @id @default(cuid())
  groupId    String
  userId     String
  lastReadAt DateTime @default(now())
  joinedAt   DateTime @default(now())

  group GroupChat @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
  @@map("group_chat_member")
}

model GroupMessage {
  id        String   @id @default(cuid())
  groupId   String
  senderId  String
  content   String   @db.VarChar(2000)
  // Optional rich media (mirrors DMs): a single GIF and/or up to 4 images.
  gifUrl    String?  @db.Text
  imageUrls String[] @default([])
  // Optional inline poll: a question + 2–6 option labels (votes in GroupPollVote).
  pollQuestion String?  @db.VarChar(300)
  pollOptions  String[] @default([])
  createdAt DateTime @default(now())

  group     GroupChat       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender    User            @relation(fields: [senderId], references: [id], onDelete: Cascade)
  pollVotes GroupPollVote[]

  @@index([groupId, createdAt])
  @@map("group_message")
}

model GroupPollVote {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  optionIdx Int
  createdAt DateTime @default(now())

  message GroupMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@map("group_poll_vote")
}

/// RMHStudy flashcard deck (#31). Decks are personal but can be shared publicly.
model FlashcardDeck {
  id          String   @id @default(cuid())
  userId      String
  title       String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  isPublic    Boolean  @default(false)
  cardCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards Flashcard[]

  @@index([userId])
  @@index([isPublic, updatedAt(sort: Desc)])
  @@map("flashcard_deck")
}

model Flashcard {
  id        String   @id @default(cuid())
  deckId    String
  front     String   @db.Text
  back      String   @db.Text
  position  Int      @default(0)
  createdAt DateTime @default(now())

  deck    FlashcardDeck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  reviews FlashcardReview[]

  @@index([deckId])
  @@map("flashcard")
}

/// Per-user spaced-repetition state for a card (SM-2). Lets several users study
/// the same (public) deck with independent schedules.
model FlashcardReview {
  id           String   @id @default(cuid())
  userId       String
  cardId       String
  easeFactor   Float    @default(2.5)
  intervalDays Int      @default(0)
  repetitions  Int      @default(0)
  dueAt        DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Flashcard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@index([userId, dueAt])
  @@map("flashcard_review")
}

model BuildVersion {
  id         String   @id @default(cuid())
  buildId    String
  version    String   @db.VarChar(20)
  changelog  String?  @db.Text
  commitHash String?  @db.VarChar(40)
  createdAt  DateTime @default(now())

  build UserBuild @relation(fields: [buildId], references: [id], onDelete: Cascade)

  @@unique([buildId, version])
  @@map("build_version")
}

model BuildCategory {
  id          String  @id @default(cuid())
  name        String  @unique @db.VarChar(50)
  slug        String  @unique @db.VarChar(50)
  description String? @db.VarChar(200)
  iconName    String? @db.VarChar(50)
  color       String? @db.VarChar(50)
  position    Int     @default(0)

  builds UserBuild[]

  @@map("build_category")
}

model BuildTag {
  id      String @id @default(cuid())
  buildId String
  name    String @db.VarChar(30)

  build UserBuild @relation(fields: [buildId], references: [id], onDelete: Cascade)

  @@unique([buildId, name])
  @@index([name])
  @@map("build_tag")
}

model BuildLike {
  id        String   @id @default(cuid())
  buildId   String
  userId    String
  createdAt DateTime @default(now())

  build UserBuild @relation(fields: [buildId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([buildId, userId])
  @@map("build_like")
}

model BuildComment {
  id        String   @id @default(cuid())
  buildId   String
  userId    String
  content   String   @db.VarChar(2000)
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent  BuildComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies BuildComment[] @relation("CommentReplies")
  build   UserBuild      @relation(fields: [buildId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([buildId, createdAt(sort: Desc)])
  @@map("build_comment")
}

model BuildView {
  id        String   @id @default(cuid())
  buildId   String
  userId    String?
  ipHash    String?
  createdAt DateTime @default(now())

  build UserBuild @relation(fields: [buildId], references: [id], onDelete: Cascade)
  user  User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([buildId, userId])
  @@unique([buildId, ipHash])
  @@map("build_view")
}

// ─── Dream Rift ───────────────────────────────────────────────────

model DreamRiftPlayer {
  id               String   @id @default(uuid())
  username         String   @unique
  highScoreEasy    Int      @default(0)
  highScoreNormal  Int      @default(0)
  highScoreHard    Int      @default(0)
  highScoreLunatic Int      @default(0)
  bestStage        Int      @default(1)
  character        String   @default("rei")
  gamesPlayed      Int      @default(1)
  totalGraze       Int      @default(0)
  spellsCaptured   Int      @default(0)
  updatedAt        DateTime @default(now()) @updatedAt

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([highScoreNormal(sort: Desc)], map: "idx_dream_rift_high_score")
  @@index([bestStage(sort: Desc)], map: "idx_dream_rift_best_stage")
}

// A single completed multiplayer (co-op) Dream Rift run. Powers the co-op
// leaderboards: highest combined squad score and longest time survived.
model DreamRiftCoopRun {
  id            String   @id @default(uuid())
  difficulty    String   @default("normal")
  combinedScore Int      @default(0)
  timeSurvived  Int      @default(0) // seconds the squad stayed alive
  stageReached  Int      @default(1)
  cleared       Boolean  @default(false)
  playerCount   Int      @default(2)
  // [{ name, charId, score }] for each squad member (host-submitted snapshot).
  players       Json
  hostUserId    String?
  hostUser      User?    @relation(fields: [hostUserId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())

  @@index([difficulty, combinedScore(sort: Desc)], map: "idx_dream_rift_coop_score")
  @@index([difficulty, timeSurvived(sort: Desc)], map: "idx_dream_rift_coop_time")
}

// RMH Farming Simulator — one persistent farm per user. The full live world
// (tiles, money, day/season/weather, inventory, seeds, tool levels, members,
// shipped value) is stored as a JSON blob; `code` is the shareable join code
// other players use to request access.
model FarmingSimFarm {
  id        String   @id @default(cuid())
  ownerId   String   @unique
  code      String   @unique
  name      String
  saveData  Json
  shippedValue Int    @default(0) // surfaced column for future leaderboards
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@map("farming_sim_farm")
}

// Tracks which Discord channel was last used for an activity per guild.
// Used by the daily recap script to know where to post recaps.
model DiscordActivityChannel {
  id             String    @id @default(cuid())
  guildId        String
  channelId      String
  activity       String    // e.g. "lights-out"
  updatedAt      DateTime  @default(now()) @updatedAt
  // Scheduled recap: set when the first player starts the daily puzzle
  recapDateKey   String?   // YYYY-MM-DD of the puzzle day to recap
  recapDueAt     DateTime? // when to send the recap (24h after first activity)

  @@unique([guildId, activity])
  @@index([recapDueAt], map: "idx_discord_activity_recap_due")
  @@map("discord_activity_channel")
}

// Tracks per-user, per-guild daily puzzle participation.
// A user completing in one guild propagates to all guilds they opened the activity in.
model DiscordDailyParticipant {
  id           String   @id @default(cuid())
  discordId    String   // Discord user ID
  guildId      String
  dateKey      String   // YYYY-MM-DD
  username     String
  status       String   @default("playing") // "playing" | "completed"
  moves        Int?
  ratingEmoji  String?
  ratingLabel  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@unique([discordId, guildId, dateKey])
  @@index([guildId, dateKey], map: "idx_discord_daily_participant_guild_date")
  @@index([discordId, dateKey], map: "idx_discord_daily_participant_user_date")
  @@map("discord_daily_participant")
}

// Tracks per-user daily puzzle progress across guilds/devices (prevents move resets)
model DiscordDailyProgress {
  id          String   @id @default(cuid())
  discordId   String
  dateKey     String   // YYYY-MM-DD
  gridJson    String   // JSON-encoded grid state
  moves       Int      @default(0)
  completed   Boolean  @default(false)
  ratingLabel String?
  ratingEmoji String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@unique([discordId, dateKey])
  @@map("discord_daily_progress")
}

// ═══════════════════════════════════════════════════════════════════════════════
// DOCTRINE ENGINE (RMH Strategies)
// ═══════════════════════════════════════════════════════════════════════════════

enum DoctrinePuzzleMode {
  ALIBI
  SPECTRUM
  OUTCAST
  CHAINLINK
  IMPOSTOR
  SAHUR_SPECIAL
}

enum DoctrineSafehouseType {
  DEV_LOG
  BUILD
  POSTMORTEM
  DECISION
  RAW_FOOTAGE
  FINANCIAL
  VOTE
}

enum DoctrineDisclosureStatus {
  CLASSIFIED
  TEASED
  DISCLOSED
  ARCHIVED
}

enum DoctrineIncidentSeverity {
  COSMETIC
  DEGRADED
  CRITICAL
  CATASTROPHIC
}

enum DoctrineIncidentStatus {
  ACTIVE
  MITIGATED
  RESOLVED
  LEGENDARY
}

enum DoctrineReactionType {
  FIRE
  BASED
  MID
  CRINGE
  TRASH
  TUNG
}

// ─── REPUTATION ─────────────────────────────────────────────────────────────

model DoctrineReputation {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalXp       Int      @default(0)
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  lastActiveAt  DateTime @default(now())
  coalitionScore Float   @default(1.0)
  sahurCount    Int      @default(0)
  ledger        DoctrineReputationLedger[]

  @@index([totalXp(sort: Desc)])
  @@map("doctrine_reputation")
}

model DoctrineReputationLedger {
  id           String             @id @default(cuid())
  reputationId String
  reputation   DoctrineReputation @relation(fields: [reputationId], references: [id], onDelete: Cascade)
  action       String
  xpDelta      Int
  reason       String
  metadata     Json?
  createdAt    DateTime           @default(now())

  @@index([reputationId, createdAt(sort: Desc)])
  @@map("doctrine_reputation_ledger")
}

// ─── PUZZLES ────────────────────────────────────────────────────────────────

model DoctrinePuzzle {
  id          String                     @id @default(cuid())
  mode        DoctrinePuzzleMode
  date        DateTime                   @db.Date
  seed        Int
  data        Json
  difficulty  Int                        @db.SmallInt
  resetsAt    DateTime
  isSahur     Boolean                    @default(false)
  submissions DoctrinePuzzleSubmission[]
  createdAt   DateTime                   @default(now())

  @@unique([mode, date])
  @@index([date(sort: Desc)])
  @@index([mode, date])
  @@map("doctrine_puzzle")
}

model DoctrinePuzzleSubmission {
  id        String         @id @default(cuid())
  puzzleId  String
  puzzle    DoctrinePuzzle @relation(fields: [puzzleId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  answer    Json
  timeMs    Int
  attempts  Int
  correct   Boolean
  score     Int
  createdAt DateTime       @default(now())

  @@unique([puzzleId, userId])
  @@index([puzzleId, score(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("doctrine_puzzle_submission")
}

model DoctrinePuzzleReplay {
  id         String             @id @default(cuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode       DoctrinePuzzleMode
  seed       Int
  data       Json
  difficulty Int                @db.SmallInt
  answer     Json?
  timeMs     Int?
  attempts   Int?
  correct    Boolean?
  score      Int?
  createdAt  DateTime           @default(now())

  @@index([userId, mode, createdAt(sort: Desc)])
  @@map("doctrine_puzzle_replay")
}

// ─── SAFEHOUSE ──────────────────────────────────────────────────────────────

model DoctrineSafehouseContent {
  id          String                @id @default(cuid())
  type        DoctrineSafehouseType
  title       String
  body        String
  minTier     String                @default("INSIDER") // PUBLIC | INSIDER | OPERATOR
  authorId    String
  mediaUrls   String[]
  reactions   DoctrineReaction[]
  accessLogs  DoctrineAccessLog[]
  publishedAt DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([minTier, publishedAt(sort: Desc)])
  @@map("doctrine_safehouse_content")
}

model DoctrineAccessLog {
  id        String                   @id @default(cuid())
  userId    String
  user      User                     @relation(fields: [userId], references: [id])
  contentId String
  content   DoctrineSafehouseContent @relation(fields: [contentId], references: [id])
  viewedAt  DateTime                 @default(now())

  @@unique([userId, contentId])
  @@index([contentId])
  @@map("doctrine_access_log")
}

// ─── DISCLOSURES ────────────────────────────────────────────────────────────

model DoctrineDisclosure {
  id            String                    @id @default(cuid())
  codename      String
  publicTitle   String
  content       String
  narrative     String
  minTierTeaser String                    @default("OPERATOR")
  status        DoctrineDisclosureStatus  @default(CLASSIFIED)
  scheduledAt   DateTime?
  teasedAt      DateTime?
  disclosedAt   DateTime?
  mediaUrls     String[]
  reactions     DoctrineReaction[]
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  @@index([status, scheduledAt])
  @@map("doctrine_disclosure")
}

// ─── RECRUITMENT ────────────────────────────────────────────────────────────

model DoctrineRecruitmentCode {
  id              String   @id @default(cuid())
  code            String   @unique
  recruiterId     String
  recruiter       User     @relation(fields: [recruiterId], references: [id])
  personalMessage String
  targetSkills    String[]
  uses            Int      @default(0)
  maxUses         Int      @default(5)
  expiresAt       DateTime
  convertedIds    String[]
  createdAt       DateTime @default(now())

  @@index([code])
  @@index([recruiterId])
  @@map("doctrine_recruitment_code")
}

// ─── INCIDENTS ──────────────────────────────────────────────────────────────

model DoctrineIncident {
  id              String                   @id @default(cuid())
  codename        String
  severity        DoctrineIncidentSeverity
  title           String
  narrative       String
  status          DoctrineIncidentStatus   @default(ACTIVE)
  firstReporterId String?
  postmortemId    String?
  timeline        DoctrineIncidentEvent[]
  reports         DoctrineIncidentReport[]
  reactions       DoctrineReaction[]
  createdAt       DateTime                 @default(now())
  resolvedAt      DateTime?

  @@index([status, createdAt(sort: Desc)])
  @@map("doctrine_incident")
}

model DoctrineIncidentEvent {
  id         String           @id @default(cuid())
  incidentId String
  incident   DoctrineIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  type       String
  message    String
  createdAt  DateTime         @default(now())

  @@index([incidentId, createdAt])
  @@map("doctrine_incident_event")
}

model DoctrineIncidentReport {
  id         String           @id @default(cuid())
  incidentId String
  incident   DoctrineIncident @relation(fields: [incidentId], references: [id])
  userId     String
  user       User             @relation(fields: [userId], references: [id])
  message    String
  createdAt  DateTime         @default(now())

  @@index([incidentId])
  @@map("doctrine_incident_report")
}

// ─── REACTIONS (polymorphic across doctrine content) ────────────────────────

model DoctrineReaction {
  id           String                    @id @default(cuid())
  userId       String
  user         User                      @relation(fields: [userId], references: [id])
  reaction     DoctrineReactionType
  safehouseId  String?
  safehouse    DoctrineSafehouseContent?  @relation(fields: [safehouseId], references: [id])
  disclosureId String?
  disclosure   DoctrineDisclosure?        @relation(fields: [disclosureId], references: [id])
  incidentId   String?
  incident     DoctrineIncident?          @relation(fields: [incidentId], references: [id])
  createdAt    DateTime                   @default(now())

  @@unique([userId, safehouseId])
  @@unique([userId, disclosureId])
  @@unique([userId, incidentId])
  @@map("doctrine_reaction")
}

// ─── SAHUR MODE ─────────────────────────────────────────────────────────────

model DoctrineSahurSession {
  id               String                       @id @default(cuid())
  dateKey          String
  timezone         String
  activatedAt      DateTime                     @default(now())
  deactivatedAt    DateTime?
  participantCount Int                          @default(0)
  participants     DoctrineSahurParticipation[]

  @@unique([dateKey, timezone])
  @@index([dateKey])
  @@map("doctrine_sahur_session")
}

model DoctrineSahurParticipation {
  id              String               @id @default(cuid())
  sessionId       String
  session         DoctrineSahurSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId          String
  user            User                 @relation(fields: [userId], references: [id])
  joinedAt        DateTime             @default(now())
  puzzlesCompleted Int                 @default(0)
  xpEarned        Int                  @default(0)

  @@unique([sessionId, userId])
  @@map("doctrine_sahur_participation")
}

model DiscordChatSession {
  discordUserId   String   @id
  username        String
  history         Json
  lastMessageId   String?
  updatedAt       DateTime @updatedAt

  @@map("discord_chat_session")
}

model VibePage {
  id                  String   @id @default(cuid())
  slug                String   @unique // short URL-safe identifier, e.g. "neon-city-3k"
  prompt              String            // original user prompt
  title               String?           // model-generated page title (tab + OG)
  description         String?           // model-generated description (OG/social)
  html                String            // full generated HTML — always mirrors the latest version
  // Generation lifecycle: a brand-new page is created up front as "generating" (with
  // a reserved slug) so the client can navigate to it immediately and the generation
  // survives a dropped streaming connection; it flips to "ready" once the build is
  // persisted, or "error" if generation failed. Existing/legacy rows default "ready".
  status              String   @default("ready") // "generating" | "ready" | "error"
  thumbnailUrl        String?           // "/api/vibe/thumb/<slug>?v=<ts>" once the screenshot is captured
  thumbnailStale      Boolean  @default(true) // true → the vibe-worker (re)renders the screenshot
  conversationHistory Json              // array of { role, content } turns for "customize" follow-ups
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  versions VibePageVersion[]

  @@index([slug])
  @@map("vibe_page")
}

// One immutable snapshot per generation step (the initial build and every
// "customize" follow-up). Lets people browse the page's history — each version is
// dated/timestamped — and branch a new customization off any earlier variant.
model VibePageVersion {
  id                  String   @id @default(cuid())
  pageId              String
  page                VibePage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  prompt              String            // the prompt that produced this version
  title               String?           // page title at this version
  description         String?           // description at this version
  html                String            // full generated HTML for this version
  conversationHistory Json              // cumulative { role, content } history up to & including this version
  createdAt           DateTime @default(now())

  @@index([pageId, createdAt])
  @@map("vibe_page_version")
}

// Stripe subscription state, synced by @better-auth/stripe via webhook.
model Subscription {
  id                   String    @id @default(cuid())
  plan                 String    // "starter" | "pro" | "enterprise"
  referenceId          String    // the owning User.id
  stripeCustomerId     String?
  stripeSubscriptionId String?
  status               String?   // active | trialing | past_due | canceled | incomplete | ...
  periodStart          DateTime?
  periodEnd            DateTime?
  cancelAtPeriodEnd    Boolean?
  seats                Int?
  trialStart           DateTime?
  trialEnd             DateTime?

  @@index([referenceId])
  @@index([stripeCustomerId])
}

// ─── Notifications ────────────────────────────────────────────────────────
// In-app notifications for social events (likes, comments, replies, follows,
// mentions, reposts). Recipient is `userId`; `actorId` is who triggered it.

enum NotificationType {
  LIKE
  COMMENT
  REPLY
  FOLLOW
  MENTION
  REPOST
  SYSTEM
}

model Notification {
  id         String           @id @default(cuid())
  userId     String // recipient
  actorId    String? // who triggered it (null for system notifications)
  type       NotificationType
  entityType String?          @db.VarChar(32) // e.g. "rmhark", "comment", "user"
  entityId   String?          @db.VarChar(64)
  preview    String?          @db.VarChar(280) // short snapshot of the content
  link       String?          @db.VarChar(500) // where clicking should take the user
  read       Boolean          @default(false)
  createdAt  DateTime         @default(now())

  user  User  @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("UserNotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, read, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notification")
}

// ─── Moderation ───────────────────────────────────────────────────────────
// User-facing reporting plus block/mute. Admins review reports via the queue.

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum ReportReason {
  SPAM
  HARASSMENT
  HATE
  VIOLENCE
  SEXUAL
  SELF_HARM
  MISINFORMATION
  ILLEGAL
  OTHER
}

model ContentReport {
  id          String       @id @default(cuid())
  reporterId  String
  reason      ReportReason
  details     String?      @db.VarChar(1000)
  // What is being reported. entityType is "rmhark" | "comment" | "user" | "build" | "dm".
  entityType  String       @db.VarChar(32)
  entityId    String       @db.VarChar(64)
  // Convenience: the user who owns the reported content (for quick triage).
  targetUserId String?

  status      ReportStatus @default(PENDING)
  resolvedById String?
  resolvedAt  DateTime?
  moderatorNote String?    @db.VarChar(1000)

  createdAt   DateTime     @default(now())

  reporter   User  @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  resolvedBy User? @relation("ReportResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([reporterId])
  @@map("content_report")
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("BlockBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlockBlocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("user_block")
}

model UserMute {
  id        String   @id @default(cuid())
  muterId   String
  mutedId   String
  createdAt DateTime @default(now())

  muter User @relation("MuteMuter", fields: [muterId], references: [id], onDelete: Cascade)
  muted User @relation("MuteMuted", fields: [mutedId], references: [id], onDelete: Cascade)

  @@unique([muterId, mutedId])
  @@index([muterId])
  @@map("user_mute")
}

// ─── Bookmarks ────────────────────────────────────────────────────────────
model RMHarkBookmark {
  id        String   @id @default(cuid())
  userId    String
  rmheetId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  rmhark RMHark @relation(fields: [rmheetId], references: [id], onDelete: Cascade)

  @@unique([userId, rmheetId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("rmheet_bookmark")
}

// ─── Achievements ─────────────────────────────────────────────────────────
// Definitions live in code (lib/achievements/catalog.ts); only unlocks are
// persisted. `progress` supports incremental achievements (e.g. "win 50 games").

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String   @db.VarChar(64) // matches a catalog key
  progress      Int      @default(0)
  unlockedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId, unlockedAt])
  @@map("user_achievement")
}

// ─── Daily Streak ─────────────────────────────────────────────────────────
model DailyStreak {
  id            String   @id @default(cuid())
  userId        String   @unique
  current       Int      @default(0)
  longest       Int      @default(0)
  lastCheckIn   DateTime?
  lastDateKey   String?  @db.VarChar(10) // YYYY-MM-DD in the user's tz
  totalCheckIns Int      @default(0)
  freezeTokens  Int      @default(0) // optional "streak freeze" inventory
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("daily_streak")
}

// ─── Cosmetics Shop ───────────────────────────────────────────────────────
// Catalog lives in code (lib/shop/catalog.ts). UserInventory records ownership
// and which item is currently equipped per slot.

enum ShopItemKind {
  THEME // unlocks a premium site theme
  PET // profile pet variant
  NAME_COLOR // username color
  BADGE // profile flair badge
  BANNER // profile banner
  POST_FLAIR // decoration shown on the user's posts
  AVATAR_FRAME // ring around the avatar
}

model UserInventory {
  id        String       @id @default(cuid())
  userId    String
  itemId    String       @db.VarChar(64) // catalog key
  kind      ShopItemKind
  equipped  Boolean      @default(false)
  acquiredAt DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId, kind])
  @@map("user_inventory")
}

// ─── Coin Ledger (tips & gifts) ───────────────────────────────────────────
enum CoinTxnType {
  TIP
  GIFT
  PURCHASE
  REWARD
  ADMIN
}

model CoinTransaction {
  id          String      @id @default(cuid())
  senderId    String?     // null for system rewards
  recipientId String
  amount      Int
  type        CoinTxnType
  note        String?     @db.VarChar(280)
  entityType  String?     @db.VarChar(32) // e.g. "rmhark", "profile"
  entityId    String?     @db.VarChar(64)
  createdAt   DateTime    @default(now())

  sender    User? @relation("CoinSender", fields: [senderId], references: [id], onDelete: SetNull)
  recipient User  @relation("CoinRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, createdAt(sort: Desc)])
  @@index([senderId, createdAt(sort: Desc)])
  @@map("coin_transaction")
}

// ─── Admin Feed Announcements ─────────────────────────────────────────────
// Pinned banners admins publish from the admin panel; rendered at the top of
// the home feed for everyone until deactivated or expired.

model FeedAnnouncement {
  id          String    @id @default(cuid())
  title       String    @db.VarChar(120)
  body        String    @db.VarChar(1000)
  linkUrl     String?   @db.VarChar(500)
  linkLabel   String?   @db.VarChar(60)
  variant     String    @default("info") @db.VarChar(16) // info | success | warning | event
  active      Boolean   @default(true)
  pinned      Boolean   @default(true)
  createdById String
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Rich attachments (mirrors RMHark): uploaded images, an embedded GIF/image
  // URL, and an optional poll. Mentions/hashtags live inline in `body`.
  imageUrls String[] @default([])
  gifUrl    String?  @db.Text

  createdBy User                  @relation(fields: [createdById], references: [id], onDelete: Cascade)
  poll      FeedAnnouncementPoll?

  @@index([active, createdAt(sort: Desc)])
  @@map("feed_announcement")
}

model FeedAnnouncementPoll {
  id             String    @id @default(cuid())
  announcementId String    @unique
  question       String    @db.VarChar(200)
  multiSelect    Boolean   @default(false)
  closesAt       DateTime? // optional scheduled close; null = never closes
  createdAt      DateTime  @default(now())

  announcement FeedAnnouncement             @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  options      FeedAnnouncementPollOption[]

  @@map("feed_announcement_poll")
}

model FeedAnnouncementPollOption {
  id       String @id @default(cuid())
  pollId   String
  text     String @db.VarChar(80)
  position Int

  poll  FeedAnnouncementPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes FeedAnnouncementPollVote[]

  @@index([pollId])
  @@map("feed_announcement_poll_option")
}

model FeedAnnouncementPollVote {
  id        String   @id @default(cuid())
  optionId  String
  userId    String
  createdAt DateTime @default(now())

  option FeedAnnouncementPollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([optionId, userId])
  @@index([optionId])
  @@map("feed_announcement_poll_vote")
}

// ─── RMHark Edit History ──────────────────────────────────────────────────
// One row per prior version, captured the moment before an edit is applied.
model RMHarkEdit {
  id        String   @id @default(cuid())
  rmheetId  String
  content   String   @db.Text
  createdAt DateTime @default(now())

  rmhark RMHark @relation(fields: [rmheetId], references: [id], onDelete: Cascade)

  @@index([rmheetId, createdAt(sort: Desc)])
  @@map("rmheet_edit")
}

// ─── Admin Audit Log ──────────────────────────────────────────────────────
model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String   @db.VarChar(64) // e.g. "report.resolve", "user.ban"
  targetType String?  @db.VarChar(32)
  targetId   String?  @db.VarChar(64)
  detail     String?  @db.VarChar(500)
  createdAt  DateTime @default(now())

  admin User @relation("AuditAdmin", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([createdAt(sort: Desc)])
  @@index([targetType, targetId])
  @@map("admin_audit_log")
}

// ─── User Strikes ─────────────────────────────────────────────────────────
model UserStrike {
  id        String    @id @default(cuid())
  userId    String
  adminId   String
  reason    String    @db.VarChar(500)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  user  User @relation("StrikeUser", fields: [userId], references: [id], onDelete: Cascade)
  admin User @relation("StrikeAdmin", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("user_strike")
}

enum RMHarkAudience {
  PUBLIC // anyone
  FOLLOWERS // the author's followers only
  PRIVATE // only the author
}

// ─── Paid post unlocks ────────────────────────────────────────────────────
model PostUnlock {
  id        String   @id @default(cuid())
  userId    String
  rmheetId  String
  pricePaid Int
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  rmhark RMHark @relation(fields: [rmheetId], references: [id], onDelete: Cascade)

  @@unique([userId, rmheetId])
  @@index([rmheetId])
  @@map("post_unlock")
}

// ─── Communities ──────────────────────────────────────────────────────────
enum CommunityRole {
  MEMBER
  MOD
  ADMIN
}

model Community {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String   @db.VarChar(60)
  description String?  @db.VarChar(500)
  color       String?  @db.VarChar(16) // accent color for the header
  icon        String?  @db.VarChar(8)  // emoji
  isPrivate   Boolean  @default(false)
  memberCount Int      @default(1)
  createdById String
  createdAt   DateTime @default(now())

  createdBy     User                    @relation("CommunityCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members       CommunityMember[]
  posts         RMHark[]
  announcements CommunityAnnouncement[]

  @@index([memberCount(sort: Desc)])
  @@map("community")
}

// Mod/admin announcements pinned to the top of a community.
model CommunityAnnouncement {
  id          String   @id @default(cuid())
  communityId String
  authorId    String
  body        String   @db.VarChar(2000)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  author    User      @relation("CommunityAnnouncementAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([communityId, createdAt(sort: Desc)])
  @@map("community_announcement")
}

model CommunityMember {
  id          String        @id @default(cuid())
  communityId String
  userId      String
  role        CommunityRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([userId])
  @@map("community_member")
}

// ─── Progression: Quests ──────────────────────────────────────────────────
// Quest definitions live in code (lib/quests/catalog.ts). One row per user per
// quest per period (daily/weekly), tracking progress + claim state.
model UserQuest {
  id        String   @id @default(cuid())
  userId    String
  questId   String   @db.VarChar(64)
  periodKey String   @db.VarChar(16) // e.g. "2026-06-21" (daily) or "2026-W25" (weekly)
  progress  Int      @default(0)
  completed Boolean  @default(false)
  claimed   Boolean  @default(false)
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questId, periodKey])
  @@index([userId, periodKey])
  @@map("user_quest")
}

// ─── Progression: Battle Pass ─────────────────────────────────────────────
// Season + tier rewards defined in code (lib/battlepass/season.ts). Premium
// track is unlocked by spending RMH coins. Claimed tiers stored as a Json array.
model UserSeasonProgress {
  id           String   @id @default(cuid())
  userId       String
  seasonId     String   @db.VarChar(32)
  seasonXp     Int      @default(0)
  premium      Boolean  @default(false)
  claimedFree  Json     @default("[]") // tier numbers claimed on the free track
  claimedPaid  Json     @default("[]") // tier numbers claimed on the premium track
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonId])
  @@map("user_season_progress")
}

/// A saved draft (scheduledAt = null) or a scheduled post (scheduledAt set).
/// Scheduled posts are materialized into real RMHarks lazily by the publisher
/// once their time is due. `publishedId` links to the created post afterwards.
model ScheduledPost {
  id          String         @id @default(cuid())
  userId      String
  content     String         @db.Text
  gifUrl      String?        @db.Text
  imageUrls   String[]       @default([])
  audience    RMHarkAudience @default(PUBLIC)
  unlockPrice Int?
  communityId String?
  poll        Json? // { question, options[], multiSelect, durationHours }
  scheduledAt DateTime? // null = plain draft
  publishedId String? // set once published → the created RMHark id
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([scheduledAt])
  @@map("scheduled_post")
}

/// One row per user per UTC day: the daily coin-wheel spin and its reward.
/// The unique [userId, dateKey] enforces once-per-day server-side.
model DailyWheelSpin {
  id        String   @id @default(cuid())
  userId    String
  dateKey   String   @db.VarChar(16) // YYYY-MM-DD (UTC)
  reward    Int
  segment   Int // winning segment index (for animation replay)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
  @@index([userId])
  @@map("daily_wheel_spin")
}

/// An interest-bearing coin vault (#18). One per user. Interest accrues lazily:
/// each deposit/withdraw first rolls elapsed time into `accrued` so we never
/// need a background job. `lastAccrued` marks the last roll-up time.
model CoinStake {
  id          String   @id @default(cuid())
  userId      String   @unique
  principal   Int      @default(0)
  accrued     Int      @default(0)
  lastAccrued DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("coin_stake")
}

/// A digital product a creator sells for coins (#19). The `deliverable` (a link,
/// code, or message) is revealed only to the creator and to buyers. A 10%
/// platform fee is burned on each sale as a coin sink.
model StorefrontProduct {
  id          String   @id @default(cuid())
  creatorId   String
  title       String   @db.VarChar(80)
  description String?  @db.VarChar(500)
  price       Int // coins
  deliverable String?  @db.Text
  active      Boolean  @default(true)
  salesCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator   User                 @relation("StorefrontCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  purchases StorefrontPurchase[]

  @@index([creatorId])
  @@map("storefront_product")
}

model StorefrontPurchase {
  id        String   @id @default(cuid())
  productId String
  buyerId   String
  pricePaid Int
  createdAt DateTime @default(now())

  product StorefrontProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyer   User              @relation("StorefrontBuyer", fields: [buyerId], references: [id], onDelete: Cascade)

  @@unique([productId, buyerId])
  @@index([buyerId])
  @@map("storefront_purchase")
}

/// A user-authored AI persona chatbot (#8). Its `systemPrompt` shapes replies;
/// conversations are per (persona, user) and stored in AiPersonaMessage.
model AiPersona {
  id           String   @id @default(cuid())
  ownerId      String
  name         String   @db.VarChar(40)
  tagline      String?  @db.VarChar(120)
  systemPrompt String   @db.VarChar(2000)
  greeting     String?  @db.VarChar(500)
  emoji        String?  @db.VarChar(8)
  // AI-generated avatar (xAI → webp in object storage). Null until the
  // background generation kicked off on create succeeds; the UI falls back to
  // the emoji until then.
  avatarUrl    String?  @db.VarChar(500)
  isPublic     Boolean  @default(true)
  chatCount    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner    User               @relation("PersonaOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  messages AiPersonaMessage[]

  @@index([ownerId])
  @@index([isPublic, chatCount(sort: Desc)])
  @@map("ai_persona")
}

model AiPersonaMessage {
  id        String   @id @default(cuid())
  personaId String
  userId    String
  role      String   @db.VarChar(12) // 'user' | 'assistant'
  content   String   @db.Text
  createdAt DateTime @default(now())

  persona AiPersona @relation(fields: [personaId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([personaId, userId, createdAt])
  @@map("ai_persona_message")
}

// ─── RMH Rideshare ─────────────────────────────────────────────────
// Free, community ride-hailing. Riders map pickup/drop-off via OSM and pick
// a ride class (RMH-X, RMH-XL, …). Drivers apply with a license + vehicle
// details; admins review and approve, after which the license image is
// deleted from storage for privacy.

enum RideClass {
  RMH_X
  RMH_XL
  RMH_COMFORT
  RMH_GREEN
  RMH_BLACK
  RMH_BIKE
  RMH_HELI
}

enum DriverApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RideStatus {
  SCHEDULED
  REQUESTED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model RideshareDriver {
  id     String                  @id @default(cuid())
  userId String                  @unique
  status DriverApplicationStatus @default(PENDING)

  // Vehicle details
  vehicleMake  String    @db.VarChar(60)
  vehicleModel String    @db.VarChar(60)
  vehicleYear  Int
  vehicleColor String    @db.VarChar(30)
  licensePlate String    @db.VarChar(16)
  vehicleClass RideClass @default(RMH_X)
  seats        Int       @default(4)

  // Availability: drivers toggle themselves online to receive ride requests.
  isOnline Boolean @default(false)

  // Live location (updated via heartbeats while a trip is active). Shown to the
  // rider on the trip map; cleared between trips client-side by staleness.
  lastLat           Float?
  lastLng           Float?
  locationUpdatedAt DateTime?

  // Aggregate rating from completed trips (rider → driver).
  ratingCount Int @default(0)
  ratingTotal Int @default(0)

  // Driver's licence number, self-reported on the application. We no longer
  // collect or store licence images.
  licenseNumber String? @db.VarChar(40)

  // Review metadata
  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String?   @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User?  @relation("RideshareApplicationReviewer", fields: [reviewedById], references: [id])

  @@index([status])
  @@map("rideshare_driver")
}

model Ride {
  id        String     @id @default(cuid())
  riderId   String
  driverId  String?
  rideClass RideClass  @default(RMH_X)
  status    RideStatus @default(REQUESTED)

  // Pickup
  pickupLabel String @db.VarChar(300)
  pickupLat   Float
  pickupLng   Float

  // Drop-off
  dropoffLabel String @db.VarChar(300)
  dropoffLat   Float
  dropoffLng   Float

  // Trip fare. `estimatedFareCents` is the quote at booking and the amount the
  // rider pays for the trip; it also drives the driver payout split.
  distanceMeters   Int?
  durationSeconds  Int?
  estimatedFareCents Int @default(0)

  // Optional rider tip, added after a completed trip and paid to the driver
  // in full. Zero until the rider tips.
  tipCents Int @default(0)

  // Set when the rider books a trip for later (status starts as SCHEDULED).
  scheduledFor DateTime?

  notes String? @db.VarChar(500)

  // Post-trip ratings (1–5). `ratingByRider` rates the driver; `ratingByDriver`
  // rates the rider.
  ratingByRider  Int?
  ratingByDriver Int?

  requestedAt DateTime  @default(now())
  acceptedAt  DateTime?
  completedAt DateTime?
  cancelledAt DateTime?
  updatedAt   DateTime  @updatedAt

  rider    User          @relation("RideRider", fields: [riderId], references: [id], onDelete: Cascade)
  driver   User?         @relation("RideDriver", fields: [driverId], references: [id])
  messages RideMessage[]

  @@index([status, rideClass, requestedAt])
  @@index([riderId])
  @@index([driverId])
  @@map("ride")
}

model RideMessage {
  id        String   @id @default(cuid())
  rideId    String
  senderId  String
  content   String   @db.VarChar(500)
  createdAt DateTime @default(now())

  ride   Ride @relation(fields: [rideId], references: [id], onDelete: Cascade)
  sender User @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([rideId, createdAt])
  @@index([senderId])
  @@map("ride_message")
}

model RideSavedPlace {
  id      String @id @default(cuid())
  userId  String
  label   String @db.VarChar(40)
  address String @db.VarChar(300)
  lat     Float
  lng     Float

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ride_saved_place")
}

// ─── Developer API: Media Upload ──────────────────────────────────────────────

enum MediaStatus {
  PENDING
  ATTACHED
}

/// Developer-API uploaded media. The `media_id` is an opaque handle; posts
/// still store the resolved `url` in RMHark.imageUrls. Reclaimed by the
/// reconciling sweep in lib/media/sweep.server.ts.
model Media {
  id          String      @id
  userId      String
  key         String
  url         String
  contentType String
  bytes       Int
  status      MediaStatus @default(PENDING)
  postId      String?
  createdAt   DateTime    @default(now())
  attachedAt  DateTime?

  user User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  post RMHark? @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([postId])
  @@index([userId])
}

/// Global daily counter for AI image generations (cost guard). One row per UTC day.
model ImageGenBudget {
  day   String @id // UTC date, "YYYY-MM-DD"
  count Int    @default(0)

  @@map("image_gen_budget")
}

/// A user-uploaded library book. PDF + cover live in R2 (keyed by id); this row
/// is the metadata the bookshelf and reader resolve. The static catalog
/// (public/library + data/library-metadata.json) is unaffected.
model LibraryDocument {
  id               String   @id @default(cuid())
  slug             String   @unique
  title            String
  description      String   @default("")
  pages            Int      @default(0)
  /// Document format: "pdf" (default) or "epub". Drives which reader renders it
  /// and the content-type / extension used to store and serve the file.
  format           String   @default("pdf")
  pdfKey           String
  coverKey         String?
  sizeBytes        Int      @default(0)
  uploadedByUserId String?
  uploadedBy       User?    @relation("LibraryUploader", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  reported         Boolean  @default(false)
  hidden           Boolean  @default(false)
  /// Curated/official entry (admin upload or migrated static catalog) — shown in
  /// the "Curated" section above community uploads.
  official         Boolean  @default(false)
  /// Manual sort order within a section (lower first); ties broken by recency.
  position         Int      @default(0)
  /// Original public/library filename when this row was migrated from the bundled
  /// static catalog. Unique so the migration is idempotent and the static list can
  /// dedupe against already-migrated books.
  originFilename   String?  @unique
  /// Preserved table of contents (chapter → page) for migrated/edited books.
  toc              Json?
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([uploadedByUserId])
  @@index([official])
  @@map("library_document")
}

/// A reader-made grouping of books (a "series" / "collection") shown as its own
/// shelf on the library page. A user owns their collections and may only add books
/// they uploaded; admins own "official" collections and may add any book. Members
/// are referenced by book slug (stable for both static-catalog and uploaded books),
/// so a collection can span both without a hard foreign key to LibraryDocument.
model LibraryCollection {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String   @default("")
  ownerUserId String?
  owner       User?    @relation("LibraryCollectionOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  /// Curated/official collection (admin-made) — surfaced above community series.
  official    Boolean  @default(false)
  /// R2 key of the collection's (AI-generated) cover image, served via
  /// /api/library/cover/<collectionId>. Null until a cover is generated.
  coverKey    String?
  hidden      Boolean  @default(false)
  /// Manual sort order across collections (lower first).
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items LibraryCollectionItem[]

  @@index([ownerUserId])
  @@index([official])
  @@map("library_collection")
}

model LibraryCollectionItem {
  id           String   @id @default(cuid())
  collectionId String
  collection   LibraryCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  /// The member book's slug (resolved to a LibraryBook at read time).
  bookSlug     String
  /// Order within the collection (lower first).
  position     Int      @default(0)
  createdAt    DateTime @default(now())

  @@unique([collectionId, bookSlug])
  @@index([collectionId])
  @@map("library_collection_item")
}

/// A regular user's appeal to raise their library upload quota, reviewed by an
/// admin in the admin panel. Approving sets the user's libraryUploadQuota.
model LibraryQuotaRequest {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation("LibraryQuotaRequests", fields: [userId], references: [id], onDelete: Cascade)
  /// The new total cap the user is asking for.
  requestedTotal  Int
  reason          String    @default("") @db.Text
  /// pending | approved | denied
  status          String    @default("pending")
  decidedByUserId String?
  createdAt       DateTime  @default(now())
  decidedAt       DateTime?

  @@index([status])
  @@index([userId])
  @@map("library_quota_request")
}
