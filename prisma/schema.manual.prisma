generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  
  sessions      Session[]
  accounts      Account[]

  // Game Relations
  echoesProfile  EchoesPlayer?
  laundryProfile LaundryPlayer?

  @@map("user")
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime
  updatedAt DateTime

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id           String    @id
  userId       String
  accountId    String
  providerId   String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  password     String?
  createdAt    DateTime
  updatedAt    DateTime

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// --- Game Models ---

model EchoesPlayer {
  id            String   @id @default(uuid())
  username      String   @unique // Legacy username, or display name
  bestTime      Float    @default(0)
  totalKills    Int      @default(0)
  totalXP       Int      @default(0)
  gamesPlayed   Int      @default(1)
  updatedAt     DateTime @default(now()) @updatedAt

  // Link to Auth User (Optional for guest play, but required for sync)
  userId        String?  @unique // One profile per user
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([bestTime(sort: Desc)])
  @@index([totalKills(sort: Desc)])
  @@index([totalXP(sort: Desc)])
}

model LaundryPlayer {
  id            String   @id @default(uuid())
  username      String   @unique
  highScore     Int      @default(0)
  gamesPlayed   Int      @default(1)
  updatedAt     DateTime @default(now()) @updatedAt

  // Link to Auth User
  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([highScore(sort: Desc)])
}
