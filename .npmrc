# Hoist the generated Prisma client to top-level node_modules/.prisma/
# so that Nitro's externalized @prisma/client chunk can resolve
# `.prisma/client/default` at runtime.
# Without this, pnpm keeps .prisma buried in .pnpm/... and Node.js
# cannot find it from .output/server/.
public-hoist-pattern[]=.prisma*
