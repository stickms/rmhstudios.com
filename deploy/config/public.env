# ─────────────────────────────────────────────────────────────────────────────
# PUBLIC (non-secret) production config — committed in PLAINTEXT, on purpose.
#
# These values are not secrets: OAuth *client IDs*, browser-shipped VITE_* URLs,
# CORS origins, and feature flags. They ship to the client or are otherwise
# public, so there is no value in encrypting them — and keeping them in
# plaintext means a dev can change a hostname or flip a flag in a normal PR with
# a fully readable diff and no key access at all.
#
# Real secrets (tokens, client *secrets*, DATABASE_URL, encryption keys) live
# encrypted in deploy/secrets/production.enc.env. See deploy/SECRETS.md.
#
# materialize-env.sh concatenates this file + the decrypted secrets into
# .env.production at deploy time; on a key collision the encrypted secret wins.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Auth (public URLs + client IDs) ─────────────────────────────────────────
BETTER_AUTH_URL=https://rmhstudios.com/
VITE_BETTER_AUTH_URL=https://rmhstudios.com/
DISCORD_CLIENT_ID=
DISCORD_ACTIVITY_CLIENT_ID=
VITE_DISCORD_ACTIVITY_CLIENT_ID=
DISCORD_BOT_CLIENT_ID=
DISCORD_DEV_GUILD_ID=
GITHUB_CLIENT_ID=
SPOTIFY_CLIENT_ID=

# ─── Feature flags ───────────────────────────────────────────────────────────
ALLOW_EMAIL_ONLY_AUTH=
VITE_ALLOW_EMAIL_ONLY_AUTH=

# ─── Realtime / CORS (public endpoints) ──────────────────────────────────────
SOCKET_CORS_ORIGIN=
VITE_SOCKET_URL=
VITE_RMHBOX_SOCKET_URL=
VITE_RMHTUBE_SOCKET_URL=
