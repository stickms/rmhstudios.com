# Active web upstream port for zero-downtime blue-green deploys.
#
# Install to /home/rmhstudios/rmhstudios-web-active.conf on the VPS — this path
# MUST match BOTH the `IncludeOptional` in deploy/apache/rmhstudios.conf AND
# ACTIVE_CONF in deploy/hotswap-web.sh. It lives in the deploy user's home (not
# /etc) because the deploy webhook is sandboxed and cannot write /etc; Apache's
# root master process reads it from home just fine.
#
# deploy/hotswap-web.sh overwrites this file; a root-owned systemd path-unit
# watching it then runs `apachectl graceful` to flip traffic between the blue
# (7005) and green (7015) web containers.
#
# If this file is absent, the vhost falls back to its default (7005), so the
# standard non-hotswap deploy keeps working unchanged.
Define WEB_UPSTREAM_PORT 7005
