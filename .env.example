# ═══════════════════════════════════════════════════════════════════════
# rmhstudios.com — Environment Variables
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/rmhstudios

# ─── Authentication (Better Auth) ────────────────────────────────────
# Server-side secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-generate-a-secure-secret
BETTER_AUTH_URL=http://localhost:7005/
VITE_BETTER_AUTH_URL=http://localhost:7005/

# Discord OAuth (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# Discord Activity — separate app for embedded games (e.g. "Lights Out")
DISCORD_ACTIVITY_CLIENT_ID=your-discord-activity-client-id
DISCORD_ACTIVITY_CLIENT_SECRET=your-discord-activity-client-secret
VITE_DISCORD_ACTIVITY_CLIENT_ID=your-discord-activity-client-id
# Bot token for posting embeds and recaps (enable Bot in the Discord Developer Portal)
DISCORD_ACTIVITY_BOT_TOKEN=

# Discord Bot — standalone bot process (can reuse activity bot token, or use a separate bot)
# If DISCORD_BOT_TOKEN is not set, falls back to DISCORD_ACTIVITY_BOT_TOKEN
DISCORD_BOT_TOKEN=
# If DISCORD_BOT_CLIENT_ID is not set, falls back to DISCORD_ACTIVITY_CLIENT_ID
DISCORD_BOT_CLIENT_ID=
# Set to a guild ID for instant command registration during development (skip global deploy delay)
DISCORD_DEV_GUILD_ID=

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Set to "true" to enable email/password auth alongside Discord
ALLOW_EMAIL_ONLY_AUTH=
VITE_ALLOW_EMAIL_ONLY_AUTH=

# ─── Encryption ──────────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM encryption of GitHub PATs
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# ─── WebSocket Servers (CORS) ────────────────────────────────────────
# REQUIRED — comma-separated allowed origins. Servers will refuse to start without this.
# Example: http://localhost:7005,https://rmhstudios.com
SOCKET_CORS_ORIGIN=http://localhost:7005

# Override per-server (optional — falls back to SOCKET_CORS_ORIGIN)
# RMHBOX_CORS_ORIGIN=
# RMHTUBE_CORS_ORIGIN=

# ─── WebSocket Server URLs (client-side) ─────────────────────────────
VITE_SOCKET_URL=http://localhost:7001/
VITE_RMHBOX_SOCKET_URL=http://localhost:7676/
VITE_RMHTUBE_SOCKET_URL=http://localhost:7003/

# ─── Webhooks ────────────────────────────────────────────────────────
# REQUIRED — GitHub deploy webhook HMAC secret. Must not be "change-me".
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=

# Bearer token for weather webhook authentication
WEATHER_WEBHOOK_SECRET=

# ─── Status Page (status.rmhstudios.com — all optional) ───
# Port the standalone status dashboard listens on (Apache proxies the subdomain
# here). Set PORT_STATUS in the deploy env files; the rest tune probing.
# PORT_STATUS=7008
# STATUS_PROBE_INTERVAL_MS=15000     # how often to re-probe every service
# STATUS_PROBE_TIMEOUT_MS=4000       # per-probe network timeout
# Uptime bars: each bar aggregates one BUCKET window; MAX_BUCKETS bars are shown.
# STATUS_BUCKET_MS=3600000           # 1h per bar
# STATUS_MAX_BUCKETS=90              # → ~90h of history shown
# STATUS_DATA_DIR=/app/db            # where status-history.json is persisted
# Public origin the website probe hits (DNS → Apache → active container) so the
# status reflects what real users see, not just whether a container is alive.
# STATUS_WEBSITE_URL=https://rmhstudios.com/
# Override the probed services wholesale (JSON array of {name,description,kind,urls}).
# The internal services are probed by compose DNS name; the website by its public URL.
# STATUS_SERVICES=

# ─── RMHbox Server Tuning (all optional — sensible defaults exist) ───
# RMHBOX_PORT=7676
# RMHBOX_SOCKET_PATH=/rmhbox-ws/
# RMHBOX_MAX_BUFFER=1048576
# RMHBOX_PING_INTERVAL=25000
# RMHBOX_PING_TIMEOUT=20000
# RMHBOX_HEARTBEAT_MS=10000
# RMHBOX_IDLE_TIMEOUT=900000        # 15 minutes
# RMHBOX_ABS_TIMEOUT=1800000        # 30 minutes
# RMHBOX_EMPTY_TIMEOUT=120000       # 2 minutes
# RMHBOX_GRACE_MS=120000            # 2 minutes
# RMHBOX_GC_INTERVAL=60000          # 1 minute
# RMHBOX_SHUTDOWN_TIMEOUT=10000     # 10 seconds

# ─── RMHTube Server Tuning (all optional — sensible defaults exist) ──
# RMHTUBE_PORT=7003
# RMHTUBE_SOCKET_PATH=/rmhtube-ws/
# RMHTUBE_MAX_BUFFER=1048576
# RMHTUBE_PING_INTERVAL=25000
# RMHTUBE_PING_TIMEOUT=20000
# RMHTUBE_SYNC_HEARTBEAT_MS=2000
# RMHTUBE_IDLE_TIMEOUT=1800000      # 30 minutes
# RMHTUBE_EMPTY_TIMEOUT=300000      # 5 minutes
# RMHTUBE_GRACE_MS=120000           # 2 minutes
# RMHTUBE_GC_INTERVAL=60000         # 1 minute
# RMHTUBE_SHUTDOWN_TIMEOUT=10000    # 10 seconds

# ─── Automated News Pipeline ─────────────────────────────────────────
# Get your API key at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Random secret used to sign the approve/reject URLs sent via Discord.
# Generate with: openssl rand -hex 32
NEWS_APPROVAL_SECRET=

# Discord webhook URL for the channel that receives article review notifications.
# Create one in: Server Settings → Integrations → Webhooks
NEWS_DISCORD_WEBHOOK_URL=

# ─── RMHVibe (page generation) ──────────────────────────────────────
# Kimi (Moonshot) is the default generation provider.
# Get your API key at: https://platform.moonshot.ai
KIMI_API_KEY=
# DeepSeek is kept as an alternate model option.
# Get your API key at: https://platform.deepseek.com
DEEPSEEK_API_KEY=
# Generated vibe pages can use a real LLM (chatbots, etc.) via the server-side
# proxy at /api/vibe/ai, which reuses DEEPSEEK_API_KEY above — the key is never
# sent to the client. Both vars below are optional:
#   VIBE_AI_MODEL — DeepSeek chat model the proxy uses (default: deepseek-chat).
#   VIBE_AI_BASE_URL — public origin baked into generated pages: it's where they
#     reach the AI proxy AND load their pre-bundled packages (React, three, …) from
#     /vibe-packages/ (run `pnpm build-vibe-packages` once to generate those).
#     Defaults to https://rmhstudios.com; set to your local origin (e.g.
#     http://localhost:7005) when generating pages you'll test locally, otherwise
#     local pages pull packages from production.
# VIBE_AI_MODEL=deepseek-chat
# VIBE_AI_BASE_URL=

# ─── RMHark AI (feed drafting + bot users) ──────────────────────────
# The "✨ generate" buttons in the feed composer/replies and the bot-worker
# (synthetic users that post throughout the day) both call DeepSeek using the
# DEEPSEEK_API_KEY above — no separate key needed. If that key is unset, the
# buttons return "unavailable" and the bot-worker simply idles.
# All vars below are optional:
#   RMHARK_AI_MODEL    — DeepSeek chat model used (default: deepseek-chat).
#   BOT_TARGET_COUNT   — how many bot users the worker maintains (default: 20).
#   BOT_POST_TICK_MS   — how often the worker considers posting (default: 300000 = 5m).
#   BOT_USER_CHECK_MS  — how often it tops up the bot pool (default: 7200000 = 2h).
#   BOT_CREATE_BATCH   — new bots minted per top-up cycle (default: 6).
#   BOT_MAX_POSTS_PER_TICK — cap on posts created per tick (default: 5).
# Bot replies (bots answer people/each other in context):
#   BOT_REPLY_TICK_MS  — how often bots check for replies to answer (default: = post tick).
#   BOT_MAX_REPLIES_PER_TICK — cap on replies created per tick (default: 4).
#   BOT_MAX_REPLY_DEPTH — stop auto-replying past this thread depth (default: 6).
#   BOT_REACTIVE_HUMAN_PROB — chance a bot answers a human who replied (default: 0.9).
#   BOT_TO_BOT_REPLY_PROB — chance a bot answers another bot (default: 0.3).
#   BOT_PROACTIVE_PROB — chance/tick a bot starts a thread on another bot's post (default: 0.4).
# ─── Bot DM responses (optional; bots answer & occasionally start DMs) ───
#   BOT_DM_TICK_MS                  — how often the worker services DMs (default: 60000 = 60s).
#   BOT_DM_LOOKBACK_MS              — only react to DMs moved within this window (default: 86400000 = 24h).
#   BOT_MAX_DM_REPLIES_PER_TICK     — cap reactive DM replies per tick (default: 4).
#   BOT_REACTIVE_DM_PROB            — probability a bot answers a human DM (default: 1.0).
#   BOT_DM_INITIATE_PROB            — probability any opener happens per tick (default: 0.15).
#   BOT_MAX_DM_OPENERS_PER_TICK     — cap bot-initiated openers per tick (default: 1).
#   BOT_DM_FOLLOWUP_SILENCE_MS      — silence before one gentle follow-up (default: 259200000 = 3d).
#   BOT_DM_ACTIVE_HUMAN_LOOKBACK_MS — window defining recently-active candidate humans (default: 604800000 = 7d).
#
# Live SSE push from the worker to the web app requires the internal bridge.
# If INTERNAL_API_SECRET is unset, DMs still send but appear on the recipient's
# next stream reconnect instead of instantly.
#   INTERNAL_API_URL    — web origin the worker POSTs (default: origin of BETTER_AUTH_URL, else http://127.0.0.1:7005).
INTERNAL_API_SECRET=
# RMHARK_AI_MODEL=deepseek-chat
# BOT_TARGET_COUNT=20

# ─── Spotify (RMHMusic) ─────────────────────────────────────────────
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# ─── Doctrine Engine (RMH Strategies) ──────────────────────────────
# No additional env vars required for the initial build.
# All features use existing PostgreSQL + in-memory cache.
# Tiers are admin-assigned via /api/doctrine/admin/tiers.

# ─── Stripe subscriptions ───────────────────────────────────────────
# Server secret key (test mode: sk_test_...). Required to enable billing.
# STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret from the Stripe dashboard endpoint (whsec_...).
# STRIPE_WEBHOOK_SECRET=whsec_...
# Recurring price IDs (monthly): Starter $20, Pro $100. Enterprise is sales-led, no price.
# STRIPE_STARTER_PRICE_ID=price_...
# STRIPE_PRO_PRICE_ID=price_...

# ─── Development / Testing ───────────────────────────────────────────
# Set to "true" to force OA invite outcome in job system (dev only)
# FORCE_OA=...

# ─── Object storage (S3-compatible: MinIO now, Cloudflare R2 later) ──────────
# MinIO defaults match the docker-compose `minio` service below.
# To migrate to R2: change ENDPOINT to your R2 S3 API URL, set the R2 access
# keys, set S3_FORCE_PATH_STYLE=false, and copy objects with rclone.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=rmhminio
S3_SECRET_ACCESS_KEY=rmhminio-dev-secret
S3_BUCKET=rmh-media
S3_FORCE_PATH_STYLE=true

# Optional CDN cache purge for media cleanup. When set, the media sweep purges
# deleted objects from the CDN edge. Leave unset to skip (S3 origin delete only).
CDN_PURGE_URL=
CDN_PURGE_TOKEN=
