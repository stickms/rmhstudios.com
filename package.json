{
  "name": "rmhstudios.com",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"next dev -p 7000\" \"pnpm run socket-server\" \"pnpm run rmhbox-server\"",
    "build": "next build && tsc --project tsconfig.server.json",
    "start": "concurrently \"next start -p 7000\" \"node dist-server/server/socket-server.js\" \"node dist-server/server/rmhbox/index.js\"",
    "socket-server": "npx tsx watch server/socket-server.ts",
    "rmhbox-server": "npx tsx watch server/rmhbox/index.ts",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:reset": "prisma db push --force-reset"
  },
  "dependencies": {
    "@fontsource/noto-color-emoji": "^5.2.11",
