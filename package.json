{
  "name": "rmhstudios.com",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite dev\" \"pnpm run socket-server\" \"pnpm run rmhbox-server\" \"pnpm run rmhtube-server\"",
    "build": "vite build && pnpm exec esbuild server/socket-server/index.ts server/rmhbox/index.ts server/rmhtube/index.ts --bundle --platform=node --target=node20 --outdir=dist-server --outbase=. --format=cjs --out-extension:.js=.cjs --packages=external --tree-shaking=true --tsconfig=tsconfig.server.json",
    "start": "concurrently \"node .output/server/index.mjs\" \"node dist-server/server/socket-server/index.cjs\" \"node dist-server/server/rmhbox/index.cjs\" \"node dist-server/server/rmhtube/index.cjs\"",
    "socket-server": "pnpm exec tsx watch --include \"server/socket-server/**/*\" --include \"server/rmhmusic/**/*\" --include \"server/shared/**/*\" server/socket-server/index.ts",
    "rmhbox-server": "pnpm exec tsx watch --include \"server/rmhbox/**/*\" --include \"server/shared/**/*\" server/rmhbox/index.ts",
    "rmhtube-server": "pnpm exec tsx watch --include \"server/rmhtube/**/*\" --include \"server/shared/**/*\" server/rmhtube/index.ts",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push --accept-data-loss",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:reset": "prisma db push --force-reset",
    "db:seed-jobs": "pnpm exec tsx scripts/seed-jobs.ts",
    "audit": "pnpm audit --audit-level=moderate"
  },
