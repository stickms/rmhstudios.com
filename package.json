{
  "name": "rmhstudios.com",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"next dev -p 7005\" \"pnpm run socket-server\" \"pnpm run collab-server\" \"pnpm run rmhbox-server\"",
    "build": "next build && esbuild server/socket-server.ts server/collab-server.ts server/rmhbox/index.ts --bundle --platform=node --outdir=dist-server --outbase=. --format=cjs --packages=external --tsconfig=tsconfig.server.json",
    "start": "concurrently \"next start -p 7005\" \"node dist-server/server/socket-server.js\" \"node dist-server/server/collab-server.js\" \"node dist-server/server/rmhbox/index.js\"",
    "socket-server": "npx tsx watch --include \"server/socket-server.ts\" server/socket-server.ts",
    "collab-server": "npx tsx watch --include \"server/collab-server.ts\" server/collab-server.ts",
    "rmhbox-server": "npx tsx watch --include \"server/rmhbox/**/*\" server/rmhbox/index.ts",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:reset": "prisma db push --force-reset",
    "db:seed-jobs": "npx tsx scripts/seed-jobs.ts"
  },
