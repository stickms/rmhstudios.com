# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# tanstack start / vinxi
.vinxi/
.output/
.tanstack/

# production
/build
/dist/

# misc
.DS_Store
*.pem
.vscode

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
# NOTE: .env.production / .env.staging are now GENERATED at deploy time by
# scripts/materialize-env.sh from deploy/config/public.env + the SOPS-encrypted
# deploy/secrets/<env>.enc.env. They stay ignored — only the encrypted source
# belongs in git.
.env
.env.local
.env.development
.env.production
.env.staging

# age / SOPS private keys — NEVER commit. The encrypted *.enc.env files in
# deploy/secrets/ are safe to commit; the decryption key is not.
*.agekey
*.age.key
keys.txt
age-key*.txt

# vercel
.vercel

# typescript
*.tsbuildinfo

# claude
.claude

/lib/generated/prisma
db/**/*
dist-server/
.venv/
package-lock.json

.pnpm-store/

# Auto-generated news staging drafts (awaiting Discord approval)
content/news/staging/*.mdx

# CLI build artifacts
cli/dist/
cli/node_modules/

# RMHBot git worktrees
.rmhbot-worktrees/

# Pre-bundled vibe packages (generated by scripts/build-vibe-packages.ts at build time)
/public/vibe-packages/

# Bazel
/bazel-*
MODULE.bazel.lock

# Local filesystem storage fallback (when S3 is not configured)
.uploads/

# deploy.sh content-addressed build-skip hashes (host-local)
.deploy/
